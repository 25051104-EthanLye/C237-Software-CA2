<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Room | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --white:#FFFFFF; --peach:#E2C1AA; --teal:#99BDBC; --blue:#A2BFCE; --dark-text:#2C3E50; --light-bg:#F8F9FA; --teal-deep:#5f8f8e; }
        * { font-family:'Nunito', sans-serif; }
        body { background:#F8F5F1; color:var(--dark-text); }
        .book-wrap { max-width:600px; margin:120px auto 60px; padding:0 18px; }
        .book-card { background:var(--white); border-radius:22px; overflow:hidden; box-shadow:0 16px 44px rgba(44,62,80,.12); border:1px solid #eee7df; }

        .book-cover { height:180px; background-size:cover; background-position:center; position:relative; }
        .book-cover.no-photo { background:linear-gradient(135deg,#8bb5b4,#5f8f8e); }
        .book-cover::after { content:''; position:absolute; inset:0; background:linear-gradient(to top, rgba(20,45,44,.82), rgba(20,45,44,.15)); }
        .book-cover-text { position:absolute; left:24px; bottom:18px; right:24px; z-index:2; color:#fff; }
        .book-cover-text h2 { font-weight:800; margin:0; text-shadow:0 2px 8px rgba(0,0,0,.35); }
        .book-cover-text p { margin:2px 0 0; font-weight:700; opacity:.95; }
        .rate-badge { position:absolute; top:16px; right:16px; z-index:2; background:rgba(255,255,255,.94); color:var(--teal-deep); font-weight:800; padding:7px 14px; border-radius:999px; box-shadow:0 2px 10px rgba(0,0,0,.18); }
        .rate-badge span { color:#8a9499; font-weight:600; font-size:.78rem; }

        .book-body { padding:26px 28px 30px; }
        .field-label { font-weight:800; font-size:.82rem; color:var(--teal-deep); text-transform:uppercase; letter-spacing:.4px; margin-bottom:7px; display:block; }
        .date-input { width:100%; border:1.5px solid var(--blue); border-radius:12px; padding:13px 14px; font-weight:700; font-size:1rem; color:var(--dark-text); outline:none; background:var(--white); }
        .date-input:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(153,189,188,.3); }

        .room-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
        .room-option input { position:absolute; opacity:0; pointer-events:none; }
        .room-card { display:block; cursor:pointer; border:1.5px solid var(--blue); border-radius:14px; padding:14px 16px; transition:all .16s; background:var(--white); }
        .room-card:hover { border-color:var(--teal); }
        .room-option input:checked + .room-card { border-color:var(--teal); background:rgba(153,189,188,.16); box-shadow:0 0 0 3px rgba(153,189,188,.25); }
        .room-name { font-weight:800; display:block; }
        .room-desc { color:#8a9499; font-weight:600; font-size:.82rem; }

        .summary { margin:22px 0; background:linear-gradient(135deg, rgba(153,189,188,.18), rgba(226,193,170,.22)); border-radius:16px; padding:18px 20px; }
        .summary-row { display:flex; justify-content:space-between; font-weight:700; color:#5b6a72; margin-bottom:6px; font-size:.95rem; }
        .summary-total { display:flex; justify-content:space-between; align-items:baseline; border-top:1.5px dashed rgba(95,143,142,.4); padding-top:12px; margin-top:4px; }
        .summary-total .label { font-weight:800; }
        .summary-total .amt { font-weight:800; font-size:1.6rem; color:var(--teal-deep); }

        .btn-book { width:100%; background:var(--teal); color:#143b3a; font-weight:800; border:none; border-radius:999px; padding:15px; font-size:1.05rem; transition:all .2s; cursor:pointer; }
        .btn-book:hover { background:var(--teal-deep); color:#fff; }
        .back-link { display:block; text-align:center; margin-top:16px; color:var(--teal-deep); font-weight:700; text-decoration:none; }
        .alert-soft { background:#ffe6e6; color:#b3261e; border-radius:12px; padding:12px 16px; font-weight:700; margin-bottom:18px; }

        /* map */
        .map-section { margin-top:26px; }
        .map-section h4 { font-weight:800; font-size:1rem; margin-bottom:10px; color:var(--dark-text); }
        .map-frame { width:100%; height:220px; border:0; border-radius:14px; box-shadow:0 4px 16px rgba(44,62,80,.1); }
    </style>
</head>
<body>

<%- include('partials/navbar') %>

<div class="book-wrap">
    <div class="book-card">
        <% if (hotel.image) { %>
            <div class="book-cover" style="background-image:url('<%= hotel.image %>');">
        <% } else { %>
            <div class="book-cover no-photo">
        <% } %>
            <span class="rate-badge">$<%= Number(hotel.price_per_night).toFixed(0) %> <span>/ night</span></span>
            <div class="book-cover-text">
                <h2><%= hotel.name %></h2>
                <p>📍 <%= hotel.location %></p>
            </div>
        </div>

        <div class="book-body">
            <% if (errors && errors.length > 0) { %>
                <div class="alert-soft"><% errors.forEach(e => { %><div><%= e %></div><% }) %></div>
            <% } %>

            <form action="/hotels/book/<%= hotel.id %>" method="POST">
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="field-label">Check-in</label>
                        <input type="date" name="check_in_date" id="checkIn" class="date-input" required>
                    </div>
                    <div class="col-6">
                        <label class="field-label">Checkout</label>
                        <input type="date" name="checkout_date" id="checkOut" class="date-input" required>
                    </div>
                </div>

                <label class="field-label">Choose your room</label>
                <div class="room-grid mb-2">
                    <label class="room-option"><input type="radio" name="room_type" value="Standard" required><span class="room-card"><span class="room-name">Standard</span><span class="room-desc">Cosy & comfy</span></span></label>
                    <label class="room-option"><input type="radio" name="room_type" value="Deluxe"><span class="room-card"><span class="room-name">Deluxe</span><span class="room-desc">Extra space</span></span></label>
                    <label class="room-option"><input type="radio" name="room_type" value="Suite"><span class="room-card"><span class="room-name">Suite</span><span class="room-desc">Top comfort</span></span></label>
                    <label class="room-option"><input type="radio" name="room_type" value="Family"><span class="room-card"><span class="room-name">Family</span><span class="room-desc">Room for all</span></span></label>
                </div>

                <div class="summary">
                    <div class="summary-row"><span id="nightsText">Select your dates</span><span id="rateText"></span></div>
                    <div class="summary-total"><span class="label">Total</span><span class="amt" id="totalText">$0.00</span></div>
                </div>

                <button type="submit" class="btn-book">Confirm booking</button>
            </form>

            <% if (hotel.location) { %>
                <div class="map-section">
                    <h4>📍 Where you'll stay</h4>
                    <iframe class="map-frame" loading="lazy" src="https://www.google.com/maps?q=<%= encodeURIComponent(hotel.location) %>&output=embed"></iframe>
                </div>
            <% } %>

            <a href="/hotels" class="back-link">&larr; Back to hotels</a>
        </div>
    </div>
</div>

<script>
    const rate = <%= Number(hotel.price_per_night) %>;
    const checkIn = document.getElementById('checkIn'), checkOut = document.getElementById('checkOut');
    const nightsText = document.getElementById('nightsText'), rateText = document.getElementById('rateText'), totalText = document.getElementById('totalText');
    const today = new Date().toISOString().split('T')[0];
    checkIn.min = today; checkOut.min = today;
    function recalc() {
        const inD = new Date(checkIn.value), outD = new Date(checkOut.value);
        if (checkIn.value && checkOut.value && outD > inD) {
            const nights = Math.round((outD - inD) / 86400000);
            nightsText.textContent = nights + (nights === 1 ? ' night' : ' nights');
            rateText.textContent = '$' + rate.toFixed(2) + ' / night';
            totalText.textContent = '$' + (nights * rate).toFixed(2);
        } else { nightsText.textContent = 'Select your dates'; rateText.textContent = ''; totalText.textContent = '$0.00'; }
    }
    checkIn.addEventListener('change', () => { checkOut.min = checkIn.value || today; recalc(); });
    checkOut.addEventListener('change', recalc);
</script>

</body>
</html>
