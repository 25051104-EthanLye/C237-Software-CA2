<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results - VividVoyage</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Nunito', sans-serif; }
        body { background-color: var(--light-bg); color: var(--dark-text); overflow-x: hidden; }

        .page-header {
            background: linear-gradient(135deg, var(--teal), var(--blue));
            color: var(--white);
            padding: 60px 50px;
            text-align: center;
        }
        .page-header h1 { font-size: 40px; font-weight: 800; margin-bottom: 10px; }

        .data-section { padding: 50px; }
        .section-title { font-size: 28px; color: var(--teal); font-weight: 800; margin-bottom: 30px; }

        /* Grid for Primary Results */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Card Styles */
        .item-card {
            background-color: var(--white); border-radius: 20px; overflow: hidden;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15); transition: transform 0.3s ease;
            border: 1px solid rgba(162, 191, 206, 0.2);
            display: flex; flex-direction: column; height: 100%;
        }
        .item-card:hover { transform: translateY(-8px); box-shadow: 0 8px 25px rgba(162, 191, 206, 0.3); }
        .item-img { height: 180px; width: 100%; background-color: var(--blue); background-size: cover; background-position: center; }
        .item-details { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; }
        .item-title { font-size: 20px; color: var(--dark-text); font-weight: 800; margin-bottom: 5px; }
        .item-subtitle { color: #888; font-size: 14px; margin-bottom: 15px; }
        .item-price { font-size: 24px; color: var(--teal); font-weight: 800; margin-top: auto; margin-bottom: 15px; }
        
        .book-btn {
            background-color: var(--white); color: var(--teal); border: 2px solid var(--teal);
            padding: 12px; border-radius: 30px; font-weight: 800; text-align: center; text-decoration: none; transition: 0.3s;
        }
        .book-btn:hover { background-color: var(--teal); color: var(--white); }

        /* Infinite Scrolling Marquee for Recommendations */
        .marquee-container {
            width: 100vw; overflow: hidden; background-color: var(--white); padding: 50px 0;
            border-top: 1px solid rgba(162, 191, 206, 0.2);
        }
        .marquee-content {
            display: flex; gap: 30px; width: max-content;
            /* 25 seconds for a smooth continuous scroll */
            animation: scrollMarquee 25s linear infinite; 
            padding-left: 30px;
        }
        .marquee-container:hover .marquee-content {
            animation-play-state: paused; /* Pauses when user hovers */
        }
        @keyframes scrollMarquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(calc(-50% - 15px)); }
        }
        .marquee-card {
            width: 320px; /* Fixed width for horizontal scrolling */
            flex-shrink: 0;
        }
    </style>
</head>
<body>

    <%- include('partials/navbar') %>

    <!-- Dynamic Header -->
    <div class="page-header">
        <h1>Results for "<%= searchDestination %>"</h1>
        <p>We found the best matches for your <%= searchType === 'flight' ? 'journey' : 'stay' %>.</p>
    </div>

    <!-- MAIN RESULTS: FLIGHTS -->
    <% if (searchType === 'flight') { %>
        <section class="data-section">
            <div class="grid-container">
                <% if (flights.length === 0) { %>
                    <h3 style="color: #888; grid-column: 1 / -1; text-align: center;">No flights found for this destination.</h3>
                <% } else { %>
                    <% flights.forEach(flight => { %>
                        <div class="item-card">
                            <!-- Placeholder image for flights -->
                            <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?auto=format&fit=crop&w=600&q=80');"></div>
                            <div class="item-details">
                                <div class="item-title">Flight <%= flight.flight_number %></div>
                                <div class="item-subtitle">To <%= flight.destination %> • <%= flight.duration %></div>
                                <div class="item-price">$<%= Number(flight.price).toFixed(2) %></div>
                                <a href="#" class="book-btn" onclick="alert('Proceeding to booking...')">Select Flight</a>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </section>

        <!-- SECONDARY RECOMMENDATIONS: HOTELS CAROUSEL -->
        <% if (hotels.length > 0) { %>
            <div class="marquee-container">
                <div style="padding: 0 50px;"><h2 class="section-title">Recommended Hotels in <%= searchDestination %></h2></div>
                <div class="marquee-content">
                    <!-- Duplicating the array items guarantees an infinite scroll loop without gaps! -->
                    <% const carouselHotels = [...hotels, ...hotels, ...hotels]; %>
                    <% carouselHotels.forEach(hotel => { %>
                        <div class="item-card marquee-card">
                            <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=600&q=80');"></div>
                            <div class="item-details">
                                <div class="item-title"><%= hotel.name %></div>
                                <div class="item-subtitle"><%= hotel.location %></div>
                                <div class="item-price">$<%= Number(hotel.price_per_night).toFixed(2) %><span style="font-size:12px; color:#888;"> /night</span></div>
                                <a href="#" class="book-btn" onclick="alert('Proceeding to hotel...')">View Hotel</a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>


    <!-- MAIN RESULTS: HOTELS -->
    <% } else { %>
        <section class="data-section">
            <div class="grid-container">
                <% if (hotels.length === 0) { %>
                    <h3 style="color: #888; grid-column: 1 / -1; text-align: center;">No hotels found for this destination.</h3>
                <% } else { %>
                    <% hotels.forEach(hotel => { %>
                        <div class="item-card">
                            <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&q=80');"></div>
                            <div class="item-details">
                                <div class="item-title"><%= hotel.name %></div>
                                <div class="item-subtitle"><%= hotel.location %></div>
                                <div class="item-price">$<%= Number(hotel.price_per_night).toFixed(2) %><span style="font-size:12px; color:#888;"> /night</span></div>
                                <a href="#" class="book-btn" onclick="alert('Proceeding to hotel...')">Reserve Room</a>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </section>

        <!-- SECONDARY RECOMMENDATIONS: FLIGHTS CAROUSEL -->
        <% if (flights.length > 0) { %>
            <div class="marquee-container">
                <div style="padding: 0 50px;"><h2 class="section-title">Flights to <%= searchDestination %></h2></div>
                <div class="marquee-content">
                    <% const carouselFlights = [...flights, ...flights, ...flights]; %>
                    <% carouselFlights.forEach(flight => { %>
                        <div class="item-card marquee-card">
                            <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1542051812-ba32e18ce6a3?auto=format&fit=crop&w=600&q=80');"></div>
                            <div class="item-details">
                                <div class="item-title">Flight <%= flight.flight_number %></div>
                                <div class="item-subtitle">To <%= flight.destination %> • <%= flight.duration %></div>
                                <div class="item-price">$<%= Number(flight.price).toFixed(2) %></div>
                                <a href="#" class="book-btn" onclick="alert('Proceeding to booking...')">Select Flight</a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    <% } %>

</body>
</html>