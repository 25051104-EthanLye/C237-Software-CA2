<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Room | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF; --peach: #E2C1AA; --teal: #99BDBC;
            --blue: #A2BFCE; --dark-text: #2C3E50; --light-bg: #F8F9FA;
            --teal-deep: #5f8f8e;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background: #F8F5F1; color: var(--dark-text); }
        .edit-wrap { max-width: 480px; margin: 130px auto 60px; padding: 0 18px; }
        .edit-card {
            background: var(--white); border-radius: 20px; overflow: hidden;
            box-shadow: 0 14px 40px rgba(44,62,80,.10); border: 1px solid #eee7df;
        }
        .edit-head { background: linear-gradient(135deg, var(--teal), var(--teal-deep)); color:#fff; padding: 24px 28px; }
        .edit-head h3 { font-weight: 800; margin: 0; }
        .edit-head p { margin: 4px 0 0; opacity: .9; font-weight: 600; }
        .edit-body { padding: 28px; }
        .context {
            background: var(--light-bg); border-radius: 12px; padding: 14px 16px; margin-bottom: 20px;
            font-weight: 700; color: #566; font-size: .92rem;
        }
        .form-label { font-weight: 800; font-size: .88rem; color: var(--teal-deep); }
        .form-select { border: 1.5px solid var(--blue); border-radius: 12px; padding: 12px 14px; font-weight: 600; }
        .form-select:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(153,189,188,.3); }
        .btn-teal { background: var(--teal); color:#143b3a; font-weight:800; border:none; border-radius:999px; padding:13px; width:100%; }
        .btn-teal:hover { background: var(--teal-deep); color:#fff; }
    </style>
</head>
<body>

<%- include('partials/navbar') %>

<div class="edit-wrap">
    <div class="edit-card">
        <div class="edit-head">
            <h3>Change your room</h3>
            <p><%= reservation.name %></p>
        </div>
        <div class="edit-body">

            <div class="context">
                📍 <%= reservation.location %><br>
                <%= new Date(reservation.check_in_date).toLocaleDateString() %>
                &rarr; <%= new Date(reservation.checkout_date).toLocaleDateString() %>
            </div>

            <form action="/reservations/<%= reservation.id %>/room" method="POST">
                <div class="mb-4">
                    <label class="form-label">Room type</label>
                    <select name="room_type" class="form-select" required>
                        <% const types = ['Standard', 'Deluxe', 'Suite', 'Family']; %>
                        <% types.forEach(t => { %>
                            <option value="<%= t %>" <%= reservation.room_type === t ? 'selected' : '' %>><%= t %></option>
                        <% }) %>
                    </select>
                </div>

                <button type="submit" class="btn-teal">Update room</button>
            </form>

            <div class="text-center mt-3">
                <a href="/reservations" style="color:var(--teal-deep); font-weight:700; text-decoration:none;">&larr; Back to reservations</a>
            </div>
        </div>
    </div>
</div>

</body>
</html>
