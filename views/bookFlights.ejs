<!DOCTYPE html>
<html>
<head>
    <title>Book Flight | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">
<div class="row justify-content-center">
<div class="col-md-6">
<div class="card shadow">

    <div class="card-header" style="background-color:#99BDBC; color:white;">
        <h3>Book Flight <%= flight.flight_number %></h3>
    </div>

    <div class="card-body">

        <div class="mb-3">
            <strong>Route:</strong>
            <%= flight.departure_location %> → <%= flight.destination %><br>
        </div>
        <div class="mb-3" data-departure="<%= flight.departure_time %>" data-duration="<%= flight.duration %>" data-arrival="<%= flight.arrival_time %>">
            <strong>Date:</strong> <%= new Date(flight.departure_date).toLocaleDateString() %>
            &nbsp;|&nbsp; <strong>Departure:</strong> <%= flight.departure_time || 'TBD' %>
            &nbsp;→&nbsp; <strong>Arrival:</strong> <span class="arrival-time"><%= flight.arrival_time || 'TBD' %></span>
        </div>
        <div class="mb-4">
            <strong>Price:</strong> $<%= Number(flight.price).toFixed(2) %>
        </div>

        <form action="/flights/book/<%= flight.id %>" method="POST">

            <div class="mb-3">
                <label class="form-label">Adults</label>
                <input type="number" name="adults" min="1" max="9" value="<%= typeof adults !== 'undefined' ? adults : 1 %>" class="form-control" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Children</label>
                <input type="number" name="children" min="0" max="9" value="<%= typeof children !== 'undefined' ? children : 0 %>" class="form-control" required>
            </div>

            <div class="card bg-light p-3 mb-3">
                <div><strong>Adults:</strong> <span id="adultsCount"><%= typeof adults !== 'undefined' ? adults : 1 %></span></div>
                <div><strong>Children:</strong> <span id="childrenCount"><%= typeof children !== 'undefined' ? children : 0 %></span></div>
                <div><strong>Total travellers:</strong> <span id="totalTravellers"><%= (typeof adults !== 'undefined' ? adults : 1) + (typeof children !== 'undefined' ? children : 0) %></span></div>
                <div><strong>Price per traveller:</strong> $<span id="pricePerTraveller"><%= Number(flight.price).toFixed(2) %></span></div>
                <div><strong>Estimated total price:</strong> $<span id="estimatedTotal"><%= (Number(flight.price) * ((typeof adults !== 'undefined' ? adults : 1) + (typeof children !== 'undefined' ? children : 0))).toFixed(2) %></span></div>
            </div>

            <div class="mb-3">
                <label class="form-label">Seat Preference</label>
                <select name="seat_preference" class="form-select" required>
                    <option value="">-- Select --</option>
                    <option value="Window">Window</option>
                    <option value="Middle">Middle</option>
                    <option value="Aisle">Aisle</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Preferred Row</label>
                <select name="row_preference" class="form-select" required>
                    <option value="">-- Select --</option>
                    <option value="Front">Front</option>
                    <option value="Middle" selected>Middle</option>
                    <option value="Back">Back</option>
                </select>
            </div>

            <div class="form-text mb-3">Seat and row preferences are subject to availability.</div>

            <button class="btn btn-primary">Confirm Booking</button>
            <a href="/flights" class="btn btn-secondary">Cancel</a>

        </form>

    </div>
</div>
</div>
</div>
</div>

<script>
// Compute arrival times client-side when DB arrival_time is missing.
function parseDurationToMinutes(s){
    if(!s) return 0;
    s = String(s);
    let mins = 0;
    const h = s.match(/(\d+)\s*h/);
    if(h) mins += Number(h[1]) * 60;
    const m = s.match(/(\d+)\s*m/);
    if(m) mins += Number(m[1]);
    if(mins === 0 && /^\d+$/.test(s)) mins = Number(s);
    return mins;
}

function computeArrival(dep, dur){
    if(!dep) return null;
    const dh = String(dep).match(/(\d{1,2}):(\d{2})/);
    if(!dh) return null;
    const depMins = Number(dh[1]) * 60 + Number(dh[2]);
    const arrMins = (depMins + parseDurationToMinutes(dur)) % 1440;
    const ah = String(Math.floor(arrMins / 60)).padStart(2,'0');
    const am = String(arrMins % 60).padStart(2,'0');
    return ah + ':' + am;
}

document.addEventListener('DOMContentLoaded', ()=>{
    const container = document.querySelector('[data-departure]');
    if(container){
        const dep = container.dataset.departure;
        const dur = container.dataset.duration;
        const arr = container.dataset.arrival;
        const span = container.querySelector('.arrival-time');
        if(span && (!arr || arr === 'null' || arr === '')){
            const computed = computeArrival(dep, dur);
            if(computed) span.textContent = computed;
        }
    }

    const adultsInput = document.querySelector('input[name="adults"]');
    const childrenInput = document.querySelector('input[name="children"]');
    const adultsCount = document.getElementById('adultsCount');
    const childrenCount = document.getElementById('childrenCount');
    const totalTravellers = document.getElementById('totalTravellers');
    const estimatedTotal = document.getElementById('estimatedTotal');
    const pricePerTraveller = document.getElementById('pricePerTraveller');

    const price = Number(<%= Number(flight.price) %>);

    function updateSummary() {
        const adultsValue = Number.parseInt(adultsInput.value, 10) || 1;
        const childrenValue = Number.parseInt(childrenInput.value, 10) || 0;
        const total = adultsValue + childrenValue;
        const totalPrice = price * total;

        adultsCount.textContent = adultsValue;
        childrenCount.textContent = childrenValue;
        totalTravellers.textContent = total;
        estimatedTotal.textContent = totalPrice.toFixed(2);
        pricePerTraveller.textContent = price.toFixed(2);
    }

    adultsInput.addEventListener('input', updateSummary);
    childrenInput.addEventListener('input', updateSummary);
    updateSummary();
});
</script>

</body>
</html>