<!DOCTYPE html>
<html>
<head>
    <title>Book Flight | VividVoyage</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top: 120px;">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">

                <div
                    class="card-header"
                    style="background-color: #99BDBC; color: white;"
                >
                    <h3 class="mb-0">
                        Book Flight <%= flight.flight_number %>
                    </h3>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <strong>Route:</strong>
                        <%= flight.departure_location || 'Singapore' %>
                        →
                        <%= flight.destination %>
                    </div>

                    <div
                        class="mb-3"
                        id="flightTimeDetails"
                        data-departure="<%= flight.departure_time || '' %>"
                        data-duration="<%= flight.duration || '' %>"
                        data-arrival="<%= flight.arrival_time || '' %>"
                    >
                        <strong>Date:</strong>
                        <%= new Date(flight.departure_date).toLocaleDateString() %>

                        &nbsp;|&nbsp;

                        <strong>Departure:</strong>
                        <%= flight.departure_time || 'TBD' %>

                        &nbsp;→&nbsp;

                        <strong>Arrival:</strong>
                        <span id="arrivalTime">
                            <%= flight.arrival_time || 'TBD' %>
                        </span>
                    </div>

                    <div class="mb-4">
                        <strong>Price per traveller:</strong>
                        $<%= Number(flight.price).toFixed(2) %>
                    </div>

                    <form
                        id="bookingForm"
                        action="/flights/book/<%= flight.id %>"
                        method="POST"
                        data-price="<%= Number(flight.price) %>"
                    >

                        <div class="mb-3">
                            <label for="adults" class="form-label">
                                Adults
                            </label>

                            <input
                                type="number"
                                name="adults"
                                id="adults"
                                min="1"
                                max="9"
                                value="<%= typeof adults !== 'undefined' ? adults : 1 %>"
                                class="form-control"
                                required
                            >
                        </div>

                        <div class="mb-3">
                            <label for="children" class="form-label">
                                Children
                            </label>

                            <input
                                type="number"
                                name="children"
                                id="children"
                                min="0"
                                max="8"
                                value="<%= typeof children !== 'undefined' ? children : 0 %>"
                                class="form-control"
                                required
                            >
                        </div>

                        <div
                            id="travellerError"
                            class="alert alert-danger d-none"
                            role="alert"
                        >
                            The total number of travellers cannot exceed 9.
                        </div>

                        <div class="card bg-light p-3 mb-3">

                            <div>
                                <strong>Adults:</strong>
                                <span id="adultsCount">
                                    <%= typeof adults !== 'undefined' ? adults : 1 %>
                                </span>
                            </div>

                            <div>
                                <strong>Children:</strong>
                                <span id="childrenCount">
                                    <%= typeof children !== 'undefined' ? children : 0 %>
                                </span>
                            </div>

                            <div>
                                <strong>Total travellers:</strong>
                                <span id="totalTravellers">
                                    <%=
                                        Number(
                                            typeof adults !== 'undefined'
                                                ? adults
                                                : 1
                                        ) +
                                        Number(
                                            typeof children !== 'undefined'
                                                ? children
                                                : 0
                                        )
                                    %>
                                </span>
                            </div>

                            <div>
                                <strong>Price per traveller:</strong>
                                $<span id="pricePerTraveller">
                                    <%= Number(flight.price).toFixed(2) %>
                                </span>
                            </div>

                            <div>
                                <strong>Estimated total price:</strong>
                                $<span id="estimatedTotal">
                                    <%=
                                        (
                                            Number(flight.price) *
                                            (
                                                Number(
                                                    typeof adults !== 'undefined'
                                                        ? adults
                                                        : 1
                                                ) +
                                                Number(
                                                    typeof children !== 'undefined'
                                                        ? children
                                                        : 0
                                                )
                                            )
                                        ).toFixed(2)
                                    %>
                                </span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label
                                for="seatPreference"
                                class="form-label"
                            >
                                Seat Preference
                            </label>

                            <select
                                name="seat_preference"
                                id="seatPreference"
                                class="form-select"
                                required
                            >
                                <option value="">
                                    -- Select --
                                </option>

                                <option value="Window">
                                    Window
                                </option>

                                <option value="Middle">
                                    Middle
                                </option>

                                <option value="Aisle">
                                    Aisle
                                </option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label
                                for="rowPreference"
                                class="form-label"
                            >
                                Preferred Row
                            </label>

                            <select
                                name="row_preference"
                                id="rowPreference"
                                class="form-select"
                                required
                            >
                                <option value="">
                                    -- Select --
                                </option>

                                <option value="Front">
                                    Front
                                </option>

                                <option value="Middle">
                                    Middle
                                </option>

                                <option value="Back">
                                    Back
                                </option>
                            </select>
                        </div>

                        <div class="form-text mb-3">
                            Seat and row preferences are subject to availability.
                        </div>

                        <button
                            type="submit"
                            id="confirmBookingButton"
                            class="btn btn-primary"
                        >
                            Confirm Booking
                        </button>

                        <a
                            href="/flights"
                            class="btn btn-secondary"
                        >
                            Cancel
                        </a>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
function parseDurationToMinutes(duration) {
    if (!duration) {
        return 0;
    }

    const durationText = String(duration);
    let totalMinutes = 0;

    const hoursMatch = durationText.match(/(\d+)\s*h/i);
    const minutesMatch = durationText.match(/(\d+)\s*m/i);

    if (hoursMatch) {
        totalMinutes += Number(hoursMatch[1]) * 60;
    }

    if (minutesMatch) {
        totalMinutes += Number(minutesMatch[1]);
    }

    if (
        totalMinutes === 0 &&
        /^\d+$/.test(durationText.trim())
    ) {
        totalMinutes = Number(durationText);
    }

    return totalMinutes;
}

function computeArrivalTime(departure, duration) {
    if (!departure) {
        return null;
    }

    const departureMatch =
        String(departure).match(/(\d{1,2}):(\d{2})/);

    if (!departureMatch) {
        return null;
    }

    const departureMinutes =
        Number(departureMatch[1]) * 60 +
        Number(departureMatch[2]);

    const durationMinutes =
        parseDurationToMinutes(duration);

    const arrivalMinutes =
        (departureMinutes + durationMinutes) % 1440;

    const arrivalHours =
        String(
            Math.floor(arrivalMinutes / 60)
        ).padStart(2, '0');

    const arrivalRemainingMinutes =
        String(
            arrivalMinutes % 60
        ).padStart(2, '0');

    return (
        arrivalHours +
        ':' +
        arrivalRemainingMinutes
    );
}

document.addEventListener('DOMContentLoaded', function () {
    const flightTimeDetails =
        document.getElementById('flightTimeDetails');

    const arrivalTime =
        document.getElementById('arrivalTime');

    if (flightTimeDetails && arrivalTime) {
        const departure =
            flightTimeDetails.dataset.departure;

        const duration =
            flightTimeDetails.dataset.duration;

        const existingArrival =
            flightTimeDetails.dataset.arrival;

        if (
            !existingArrival ||
            existingArrival === 'null' ||
            existingArrival === 'undefined'
        ) {
            const computedArrival =
                computeArrivalTime(
                    departure,
                    duration
                );

            if (computedArrival) {
                arrivalTime.textContent =
                    computedArrival;
            }
        }
    }

    const bookingForm =
        document.getElementById('bookingForm');

    const adultsInput =
        document.getElementById('adults');

    const childrenInput =
        document.getElementById('children');

    const adultsCount =
        document.getElementById('adultsCount');

    const childrenCount =
        document.getElementById('childrenCount');

    const totalTravellers =
        document.getElementById('totalTravellers');

    const pricePerTraveller =
        document.getElementById('pricePerTraveller');

    const estimatedTotal =
        document.getElementById('estimatedTotal');

    const travellerError =
        document.getElementById('travellerError');

    const confirmBookingButton =
        document.getElementById(
            'confirmBookingButton'
        );

    const price =
        Number(bookingForm.dataset.price);

    function updateSummary() {
        let adultsValue =
            Number.parseInt(
                adultsInput.value,
                10
            );

        let childrenValue =
            Number.parseInt(
                childrenInput.value,
                10
            );

        if (
            !Number.isInteger(adultsValue) ||
            adultsValue < 1
        ) {
            adultsValue = 1;
        }

        if (
            !Number.isInteger(childrenValue) ||
            childrenValue < 0
        ) {
            childrenValue = 0;
        }

        const total =
            adultsValue + childrenValue;

        const totalPrice =
            price * total;

        adultsCount.textContent =
            adultsValue;

        childrenCount.textContent =
            childrenValue;

        totalTravellers.textContent =
            total;

        pricePerTraveller.textContent =
            price.toFixed(2);

        estimatedTotal.textContent =
            totalPrice.toFixed(2);

        if (total > 9) {
            travellerError.classList.remove(
                'd-none'
            );

            confirmBookingButton.disabled =
                true;
        } else {
            travellerError.classList.add(
                'd-none'
            );

            confirmBookingButton.disabled =
                false;
        }
    }

    adultsInput.addEventListener(
        'input',
        updateSummary
    );

    childrenInput.addEventListener(
        'input',
        updateSummary
    );

    bookingForm.addEventListener(
        'submit',
        function (event) {
            const adultsValue =
                Number.parseInt(
                    adultsInput.value,
                    10
                );

            const childrenValue =
                Number.parseInt(
                    childrenInput.value,
                    10
                );

            if (
                !Number.isInteger(adultsValue) ||
                adultsValue < 1 ||
                adultsValue > 9
            ) {
                event.preventDefault();

                alert(
                    'Adults must be between 1 and 9.'
                );

                return;
            }

            if (
                !Number.isInteger(childrenValue) ||
                childrenValue < 0 ||
                childrenValue > 8
            ) {
                event.preventDefault();

                alert(
                    'Children must be between 0 and 8.'
                );

                return;
            }

            if (
                adultsValue + childrenValue > 9
            ) {
                event.preventDefault();

                alert(
                    'The total number of travellers cannot exceed 9.'
                );
            }
        }
    );

    updateSummary();
});
</script>

</body>
</html>