<!DOCTYPE html>
<html>
<head>
    <title>My Bookings | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color:#99BDBC;">My Flight Bookings</h2>
            <small class="text-muted">Manage your booked flights</small>
        </div>
        <a href="/flights" class="btn btn-primary">+ Book Another Flight</a>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>Flight</th>
                        <th>Destination</th>
                        <th>Date / Time</th>
                        <th>Seat</th>
                        <th>Price</th>
                        <th width="220">Actions</th>
                    </tr>
                </thead>
                <tbody>

                <% if(bookings.length === 0){ %>
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            You have no flight bookings yet.
                        </td>
                    </tr>
                <% } else { %>
                    <% bookings.forEach(b => { %>
                    <tr>
                        <td><strong><%= b.flight_number %></strong></td>
                        <td><%= b.destination %></td>
                        <td>
                            <%= new Date(b.departure_date).toLocaleDateString() %>
                            @ <%= b.departure_time %>
                        </td>
                        <td><span class="badge bg-info text-dark"><%= b.seat_preference %></span></td>
                        <td>$<%= Number(b.price).toFixed(2) %></td>
                        <td>
                            <a href="/bookings/<%= b.id %>/seat" class="btn btn-warning btn-sm">Change Seat</a>
                            <form action="/bookings/<%= b.id %>/cancel" method="POST" class="d-inline">
                                <button class="btn btn-danger btn-sm" onclick="return confirm('Cancel this booking?')">Cancel</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                <% } %>

                </tbody>
            </table>

        </div>
    </div>
</div>

</body>
</html>