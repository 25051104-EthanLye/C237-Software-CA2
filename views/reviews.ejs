```ejs
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>VividVoyage | Reviews</title>

    <!-- Nunito Font -->
    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap"
          rel="stylesheet">


    <style>

        /* =====================================================
           COLOUR PALETTE
        ===================================================== */

        :root {

            --white: #FFFFFF;

            --sand: #E2C1AA;

            --teal: #99BDBC;

            --blue-grey: #A2BFCE;

            --dark: #2F3A3F;

            --muted: #6F8384;

            --light-sand: #F6EDE7;

            --light-teal: #EDF5F4;

        }


        /* =====================================================
           GENERAL
        ===================================================== */

        * {
            box-sizing: border-box;
        }


        body {

            margin: 0;

            font-family: 'Nunito', sans-serif;

            background:
                linear-gradient(
                    180deg,
                    #FFFFFF 0%,
                    #F8FBFB 100%
                );

            color: var(--dark);

            min-height: 100vh;

        }


        /* =====================================================
           HEADER
        ===================================================== */

        header {

            background: var(--white);

            padding: 20px 7%;

            display: flex;

            justify-content: space-between;

            align-items: center;

            border-bottom: 1px solid #E8EEEE;

            position: sticky;

            top: 0;

            z-index: 10;

        }


        .logo {

            font-size: 1.7rem;

            font-weight: 900;

            color: var(--teal);

            letter-spacing: 0.5px;

        }


        nav {

            display: flex;

            gap: 30px;

            align-items: center;

        }


        nav a {

            text-decoration: none;

            color: var(--muted);

            font-weight: 700;

        }


        nav a:hover {

            color: var(--teal);

        }


        /* =====================================================
           HERO
        ===================================================== */

        .hero {

            padding: 75px 20px 100px;

            text-align: center;

            color: white;

            background:

                linear-gradient(
                    135deg,
                    rgba(43, 58, 74, 0.35),
                    rgba(153, 189, 188, 0.35)
                ),

                linear-gradient(
                    120deg,
                    var(--sand),
                    var(--teal),
                    var(--blue-grey)
                );

        }


        .hero h1 {

            margin: 0 0 10px;

            font-size: 3rem;

            font-weight: 900;

        }


        .hero p {

            margin: 0;

            font-size: 1.1rem;

            font-weight: 600;

        }


        /* =====================================================
           MAIN CONTAINER
        ===================================================== */

        .container {

            max-width: 1100px;

            margin: -50px auto 80px;

            padding: 0 25px;

            position: relative;

        }


        /* =====================================================
           TOP ACTION BAR
        ===================================================== */

        .top-bar {

            background: white;

            padding: 25px 30px;

            border-radius: 20px;

            box-shadow:
                0 10px 30px
                rgba(43, 58, 74, 0.08);

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-bottom: 30px;

        }


        .top-bar h2 {

            margin: 0;

            color: var(--dark);

            font-size: 1.5rem;

        }


        /* =====================================================
           ADD REVIEW BUTTON
        ===================================================== */

        .add-button {

            text-decoration: none;

            background: var(--teal);

            color: white;

            padding: 13px 25px;

            border-radius: 30px;

            font-weight: 800;

            transition: 0.2s;

        }


        .add-button:hover {

            background: #7FA9A8;

            transform: translateY(-2px);

        }


        /* =====================================================
           REVIEW GRID
        ===================================================== */

        .review-grid {

            display: grid;

            grid-template-columns:
                repeat(
                    auto-fit,
                    minmax(300px, 1fr)
                );

            gap: 25px;

        }


        /* =====================================================
           REVIEW CARD
        ===================================================== */

        .review-card {

            background: white;

            border-radius: 20px;

            padding: 25px;

            border: 1px solid #E8EEEE;

            box-shadow:
                0 8px 25px
                rgba(43, 58, 74, 0.07);

            transition: 0.2s;

            display: flex;

            flex-direction: column;

        }


        .review-card:hover {

            transform: translateY(-4px);

            box-shadow:
                0 15px 35px
                rgba(43, 58, 74, 0.13);

        }


        /* =====================================================
           USER SECTION
        ===================================================== */

        .user-section {

            display: flex;

            align-items: center;

            gap: 12px;

            margin-bottom: 15px;

        }


        .avatar {

            width: 48px;

            height: 48px;

            border-radius: 50%;

            background:

                linear-gradient(
                    135deg,
                    var(--sand),
                    var(--blue-grey)
                );

            display: flex;

            align-items: center;

            justify-content: center;

            color: white;

            font-weight: 900;

            font-size: 1.1rem;

        }


        .user-info h3 {

            margin: 0;

            font-size: 1rem;

            color: var(--dark);

        }


        .destination {

            color: var(--teal);

            font-size: 0.85rem;

            font-weight: 700;

        }


        /* =====================================================
           RATING
        ===================================================== */

        .rating {

            color: var(--sand);

            font-size: 1.2rem;

            margin-bottom: 12px;

            letter-spacing: 2px;

        }


        /* =====================================================
           REVIEW TEXT
        ===================================================== */

        .review-text {

            line-height: 1.6;

            color: var(--dark);

            margin-bottom: 20px;

            flex: 1;

        }


        .review-date {

            font-size: 0.8rem;

            color: var(--muted);

            margin-bottom: 15px;

        }


        /* =====================================================
           ACTION BUTTONS
        ===================================================== */

        .actions {

            display: flex;

            gap: 10px;

        }


        .edit-button,
        .delete-button {

            border: none;

            padding: 9px 18px;

            border-radius: 20px;

            font-family: 'Nunito', sans-serif;

            font-weight: 700;

            cursor: pointer;

            text-decoration: none;

        }


        .edit-button {

            background: var(--light-teal);

            color: var(--teal);

        }


        .edit-button:hover {

            background: var(--teal);

            color: white;

        }


        .delete-button {

            background: #FBE8E3;

            color: #B5452F;

        }


        .delete-button:hover {

            background: #E2C1AA;

            color: white;

        }


        /* =====================================================
           EMPTY STATE
        ===================================================== */

        .empty {

            background: white;

            padding: 60px 30px;

            border-radius: 20px;

            text-align: center;

            box-shadow:
                0 10px 30px
                rgba(43, 58, 74, 0.07);

        }


        .empty h2 {

            color: var(--teal);

        }


        /* =====================================================
           RESPONSIVE
        ===================================================== */

        @media (max-width: 700px) {

            header {

                flex-direction: column;

                gap: 15px;

            }


            nav {

                gap: 15px;

                flex-wrap: wrap;

                justify-content: center;

            }


            .top-bar {

                flex-direction: column;

                gap: 20px;

                text-align: center;

            }


            .hero h1 {

                font-size: 2.2rem;

            }

        }

    </style>

</head>


<body>


<!-- =====================================================
     HEADER
===================================================== -->

<header>

    <div class="logo">
        VividVoyage
    </div>


    <nav>

        <a href="/flights">
            Flights
        </a>

        <a href="/hotels">
            Hotels
        </a>

        <a href="/itinerary">
            Itinerary
        </a>

        <a href="/reviews">
            Reviews
        </a>

    </nav>

</header>


<!-- =====================================================
     HERO
===================================================== -->

<section class="hero">

    <h1>
        Travel Reviews
    </h1>

    <p>
        Discover unforgettable journeys from fellow travellers
    </p>

</section>


<!-- =====================================================
     MAIN
===================================================== -->

<main class="container">


    <!-- TOP BAR -->

    <div class="top-bar">

        <h2>
            Traveller Experiences
        </h2>


        <% if (user) { %>

            <a
                href="/reviews/add"
                class="add-button"
            >
                + Write a Review
            </a>

        <% } %>

    </div>


    <!-- =================================================
         REVIEWS
    ================================================= -->

    <% if (reviews.length === 0) { %>


        <div class="empty">

            <h2>
                No reviews yet ✈️
            </h2>

            <p>
                Be the first traveller to share your experience!
            </p>

        </div>


    <% } else { %>


        <div class="review-grid">


            <% reviews.forEach(function(review) { %>


                <div class="review-card">


                    <!-- USER -->

                    <div class="user-section">

                        <div class="avatar">

                            <%= review.name
                                ? review.name
                                    .split(' ')
                                    .map(n => n[0])
                                    .join('')
                                    .substring(0, 2)
                                    .toUpperCase()
                                : 'U'
                            %>

                        </div>


                        <div class="user-info">

                            <h3>
                                <%= review.name || 'Traveller' %>
                            </h3>


                            <div class="destination">

                                📍
                                <%= review.destination %>

                            </div>

                        </div>

                    </div>


                    <!-- RATING -->

                    <div class="rating">

                        <% for (let i = 1; i <= 5; i++) { %>

                            <%= i <= review.rating
                                ? '★'
                                : '☆'
                            %>

                        <% } %>

                    </div>


                    <!-- REVIEW -->

                    <div class="review-text">

                        <%= review.text %>

                    </div>


                    <!-- DATE -->

                    <div class="review-date">

                        <%= new Date(review.date)
                            .toLocaleDateString(
                                'en-GB',
                                {
                                    day: 'numeric',
                                    month: 'short',
                                    year: 'numeric'
                                }
                            )
                        %>

                    </div>


                    <!-- ACTIONS -->

                    <% if (
                        user &&
                        user.id == review.user_id
                    ) { %>


                        <div class="actions">


                            <!-- EDIT -->

                            <a
                                href="/reviews/edit/<%= review.id %>"
                                class="edit-button"
                            >
                                ✏️ Edit
                            </a>


                            <!-- DELETE -->

                            <form
                                action="/reviews/delete/<%= review.id %>"
                                method="POST"
                                onsubmit="
                                    return confirm(
                                        'Are you sure you want to delete this review?'
                                    );
                                "
                            >

                                <button
                                    type="submit"
                                    class="delete-button"
                                >
                                    🗑 Delete
                                </button>

                            </form>


                        </div>


                    <% } %>


                </div>


            <% }); %>


        </div>


    <% } %>


</main>


</body>

</html>
```
