<%- include('partials/navbar') %>

<!-- Import Nunito Font -->
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">

<style>
    :root {
        --white: #FFFFFF;
        --desert-sand: #E2C1AA;
        --morningside: #99BDBC;
        --cadet-grey: #A2BFCE;
        --dark-text: #333333;
    }

    body {
        font-family: 'Nunito', sans-serif;
        background-color: #f8fbfb; /* Very soft tint to make white cards pop */
        margin: 0;
        padding: 0;
    }

    .profile-container {
        max-width: 900px;
        margin: 50px auto;
        padding: 20px;
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 30px;
    }

    /* --- Sidebar: Greeting & Picture --- */
    .profile-sidebar {
        background-color: var(--white);
        border-radius: 20px;
        padding: 40px 20px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(153, 189, 188, 0.2);
        border: 1px solid rgba(162, 191, 206, 0.3);
        height: fit-content;
    }

    .profile-greeting {
        color: var(--morningside);
        font-weight: 800;
        font-size: 24px;
        margin-top: 20px;
        margin-bottom: 5px;
    }

    .profile-subtext {
        color: var(--cadet-grey);
        font-weight: 600;
        font-size: 15px;
        margin-bottom: 25px;
    }

    /* Profile Image & Upload Button */
    .profile-image-container {
        position: relative;
        width: 150px;
        height: 150px;
        margin: 0 auto;
    }

    .profile-image-container img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--desert-sand);
    }

    .image-upload-btn {
        position: absolute;
        bottom: 5px;
        right: 5px;
        background-color: var(--morningside);
        color: var(--white);
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        cursor: pointer;
        font-size: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        transition: background-color 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .image-upload-btn:hover {
        background-color: var(--cadet-grey);
    }

    /* --- Main Content: Forms & Actions --- */
    .profile-main {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .profile-card {
        background-color: var(--white);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(153, 189, 188, 0.2);
        border: 1px solid rgba(162, 191, 206, 0.3);
    }

    .profile-card h2 {
        color: var(--morningside);
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 20px;
        border-bottom: 2px solid var(--desert-sand);
        padding-bottom: 10px;
    }

    /* Form Inputs */
    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        color: var(--cadet-grey);
        font-weight: 800;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .form-group input {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid var(--cadet-grey);
        border-radius: 12px;
        font-size: 16px;
        font-family: 'Nunito', sans-serif;
        color: var(--dark-text);
        outline: none;
        transition: border-color 0.3s;
        box-sizing: border-box;
    }

    .form-group input:focus {
        border-color: var(--morningside);
    }

    .btn-save {
        background-color: var(--morningside);
        color: var(--white);
        padding: 14px 25px;
        border: none;
        border-radius: 30px;
        font-size: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
        font-family: 'Nunito', sans-serif;
    }

    .btn-save:hover {
        background-color: var(--desert-sand);
        box-shadow: 0 5px 15px rgba(226, 193, 170, 0.4);
    }

    /* Itinerary Buttons */
    .itinerary-actions {
        display: flex;
        gap: 15px;
    }

    .btn-itinerary {
        flex: 1;
        text-align: center;
        background-color: var(--white);
        color: var(--morningside);
        border: 2px solid var(--morningside);
        padding: 12px;
        border-radius: 15px;
        text-decoration: none;
        font-weight: 800;
        transition: all 0.3s;
    }

    .btn-itinerary:hover {
        background-color: var(--morningside);
        color: var(--white);
    }

    .btn-itinerary.create {
        background-color: var(--desert-sand);
        border-color: var(--desert-sand);
        color: var(--white);
    }

    .btn-itinerary.create:hover {
        background-color: var(--cadet-grey);
        border-color: var(--cadet-grey);
    }
</style>

<div class="profile-container">
    
    <!-- Sidebar: Greeting & Picture -->
    <div class="profile-sidebar">
        <div class="profile-image-container">
            <!-- Using UI Avatars default, but script below allows visual photo upload preview -->
            <img src="https://ui-avatars.com/api/?name=<%= userData.username %>&background=99BDBC&color=fff&size=150" id="profilePicPreview" alt="Profile Picture">
            
            <label for="profileUpload" class="image-upload-btn" title="Upload New Picture">📷</label>
            <input type="file" id="profileUpload" style="display: none;" accept="image/*">
        </div>
        
        <h1 class="profile-greeting">Welcome back,<br><%= userData.username %>!</h1>
        <p class="profile-subtext">Ready for your next relaxing getaway?</p>
        
        <!-- Display Success or Error Messages -->
        <% if (messages.success) { %>
            <div style="color: #009933; background: #e6ffed; padding: 10px; border-radius: 8px; font-weight: bold; font-size: 14px; margin-bottom: 15px;">
                <%= messages.success %>
            </div>
        <% } %>
        <% if (messages.error) { %>
            <div style="color: #cc0000; background: #ffe6e6; padding: 10px; border-radius: 8px; font-weight: bold; font-size: 14px; margin-bottom: 15px;">
                <%= messages.error %>
            </div>
        <% } %>
    </div>

    <!-- Main Content: Forms & Itinerary -->
    <div class="profile-main">
        
        <!-- Quick Itinerary Actions -->
        <div class="profile-card">
            <h2>Your Travel Itineraries</h2>
            <p style="color: var(--cadet-grey); font-weight: 600; margin-bottom: 20px;">Manage your holidays or start planning a fresh adventure.</p>
            <div class="itinerary-actions">
                <a href="/trips" class="btn-itinerary">View My Itinerary</a>
                <a href="/trips/add" class="btn-itinerary create">✨ Create Itinerary</a>
            </div>
        </div>

        <!-- Edit Profile Details -->
        <div class="profile-card">
            <h2>Update Account Details</h2>
            <form action="/profile/edit" method="POST">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" value="<%= userData.username %>" required>
                </div>
                
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" value="<%= userData.email %>" required>
                </div>

                <div class="form-group">
                    <label>Contact Number</label>
                    <input type="text" name="contact" value="<%= userData.contact || '' %>" placeholder="Enter your contact number">
                </div>

                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" name="password" placeholder="Leave blank to keep your current password">
                </div>

                <button type="submit" class="btn-save">Save Changes</button>
            </form>
        </div>

    </div>
</div>

<!-- JavaScript to visually preview the uploaded profile picture -->
<script>
    document.getElementById('profileUpload').addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('profilePicPreview').src = e.target.result;
            }
            reader.readAsDataURL(file);
        }
    });
</script>