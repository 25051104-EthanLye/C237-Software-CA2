<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Reservations | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF; --peach: #E2C1AA; --teal: #99BDBC;
            --blue: #A2BFCE; --dark-text: #2C3E50; --light-bg: #F8F9FA;
            --teal-deep: #5f8f8e;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background: #F8F5F1; color: var(--dark-text); }
        .res-wrap { max-width: 900px; margin: 130px auto 60px; padding: 0 18px; }
        .res-head { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 14px; }
        .res-head h1 { font-weight: 800; letter-spacing: -.5px; }
        .filter-input {
            border: 1.5px solid var(--blue); border-radius: 999px; padding: 10px 18px;
            font-weight: 600; outline: none; min-width: 240px;
        }
        .filter-input:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(153,189,188,.3); }

        .res-card {
            background: var(--white); border: 1px solid #eee7df; border-radius: 18px;
            padding: 22px 24px; margin-top: 18px; box-shadow: 0 6px 20px rgba(44,62,80,.06);
            display: flex; justify-content: space-between; gap: 18px; flex-wrap: wrap;
        }
        .res-card h3 { font-weight: 800; margin-bottom: 2px; }
        .res-loc { color: var(--teal-deep); font-weight: 700; font-size: .9rem; margin-bottom: 10px; }
        .res-meta { font-size: .92rem; color: #566; font-weight: 600; }
        .res-meta strong { color: var(--dark-text); }
        .room-pill {
            display:inline-block; background: rgba(162,191,206,.3); color:#3f5a6b;
            padding: 3px 12px; border-radius: 999px; font-size: .8rem; font-weight: 800; margin-top: 8px;
        }
        .badge-status { font-size: .75rem; font-weight: 800; padding: 5px 13px; border-radius: 999px; }
        .badge-upcoming  { background:#dcecec; color: var(--teal-deep); }
        .badge-ongoing   { background: var(--peach); color:#7a4a30; }
        .badge-completed { background:#e7ecf1; color:#5a6b78; }
        .total-line { font-weight: 800; font-size: 1.1rem; margin-top: 6px; }
        .actions { display: flex; flex-direction: column; gap: 8px; justify-content: center; min-width: 150px; }
        .btn-change { background: var(--teal); color:#143b3a; font-weight:800; border:none; border-radius:999px; padding:9px 16px; }
        .btn-change:hover { background: var(--teal-deep); color:#fff; }
        .btn-cancel { background:#f0d0c8; color:#8a3324; font-weight:800; border:none; border-radius:999px; padding:9px 16px; }
        .btn-cancel:hover { background:#e6b6ab; }
        .empty {
            text-align: center; color:#7d8a92; background: var(--white);
            border-radius: 18px; padding: 50px 30px; margin-top: 24px; border: 1px dashed var(--blue);
        }
    </style>
</head>
<body>

<%- include('partials/navbar') %>

<div class="res-wrap">
    <div class="res-head">
        <h1>My reservations</h1>
        <% if (reservations.length > 0) { %>
            <input type="text" id="filter" class="filter-input" placeholder="🔍 Filter by hotel or city...">
        <% } %>
    </div>

    <% if (reservations.length === 0) { %>
        <div class="empty">
            <h4 style="font-weight:800;">No stays booked yet</h4>
            <p class="mb-3">When you reserve a room it'll show up here.</p>
            <a href="/hotels" class="btn-change" style="text-decoration:none;">Browse hotels</a>
        </div>
    <% } else { %>
        <% reservations.forEach(r => {
            // --- computed on the server from the dates (no extra DB columns needed) ---
            const oneDay = 1000 * 60 * 60 * 24;
            const inD  = new Date(r.check_in_date);
            const outD = new Date(r.checkout_date);
            const nights = Math.max(1, Math.round((outD - inD) / oneDay));
            const total  = (nights * Number(r.price_per_night)).toFixed(2);

            const now = new Date(); now.setHours(0,0,0,0);
            let status = 'Upcoming', cls = 'badge-upcoming';
            if (now >= inD && now <= outD) { status = 'Ongoing';   cls = 'badge-ongoing'; }
            else if (now > outD)           { status = 'Completed'; cls = 'badge-completed'; }
        %>
            <div class="res-card" data-name="<%= (r.name + ' ' + r.location).toLowerCase() %>">
                <div style="flex:1; min-width:220px;">
                    <div class="d-flex align-items-center gap-2">
                        <h3><%= r.name %></h3>
                        <span class="badge-status <%= cls %>"><%= status %></span>
                    </div>
                    <p class="res-loc">📍 <%= r.location %></p>
                    <p class="res-meta">
                        <strong><%= new Date(r.check_in_date).toLocaleDateString() %></strong> &rarr;
                        <strong><%= new Date(r.checkout_date).toLocaleDateString() %></strong>
                        &nbsp;·&nbsp; <%= nights %> night<%= nights === 1 ? '' : 's' %>
                    </p>
                    <span class="room-pill"><%= r.room_type %> room</span>
                    <div class="total-line">$<%= total %> <span style="font-weight:600; color:#8a9499; font-size:.85rem;">total</span></div>
                </div>

                <div class="actions">
                    <a href="/reservations/<%= r.id %>/room" class="btn-change text-center" style="text-decoration:none;">Change room</a>
                    <!-- POST + confirm so a stray click / refresh can't delete a booking -->
                    <form action="/reservations/<%= r.id %>/cancel" method="POST" onsubmit="return confirm('Cancel this reservation?');">
                        <button type="submit" class="btn-cancel w-100">Cancel</button>
                    </form>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<script>
    // client-side filter — instant, no page reload (finding information requirement)
    const filter = document.getElementById('filter');
    if (filter) {
        filter.addEventListener('input', () => {
            const term = filter.value.toLowerCase();
            document.querySelectorAll('.res-card').forEach(card => {
                card.style.display = card.dataset.name.includes(term) ? '' : 'none';
            });
        });
    }
</script>

</body>
</html>
