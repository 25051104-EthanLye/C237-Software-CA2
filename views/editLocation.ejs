<!DOCTYPE html>
<html>

<head>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">

<div class="row justify-content-center">

<div class="col-md-7">

<div class="card shadow">

<div class="card-header bg-warning">

<h3>Edit Location</h3>

</div>

<div class="card-body">

<form action="/trip/<%= tripId %>/edit/<%= itinerary.id %>" method="POST">

<div class="mb-3">

<label class="form-label">Location</label>

<input
type="text"
name="location_name"
class="form-control"
value="<%= itinerary.location_name %>"
required>

</div>

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">Latitude</label>

<input
type="number"
step="any"
name="latitude"
class="form-control"
value="<%= itinerary.latitude %>">

<div class="form-text">
Example: 1.3521 (North is positive)
</div>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">Longitude</label>

<input
type="number"
step="any"
name="longitude"
class="form-control"
value="<%= itinerary.longitude %>">

<div class="form-text">
Example: 103.8198 (East is positive)
</div>

</div>

</div>

<div class="mb-3">

<label class="form-label">Visit Time</label>

<input
type="datetime-local"
name="visit_time"
class="form-control"
value="<%= itinerary.visit_time ? new Date(itinerary.visit_time).toISOString().slice(0,16) : '' %>">

</div>

<div class="d-flex justify-content-between">

<a href="/trip/<%= tripId %>"
class="btn btn-secondary">

Cancel

</a>

<button
type="submit"
class="btn btn-warning">

Save Changes

</button>

</div>

</form>

</div>

</div>

</div>

</div>

</div>

</body>
</html>