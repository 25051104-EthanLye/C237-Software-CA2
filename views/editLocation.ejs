<!DOCTYPE html>
<html>

<head>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">

<div class="row justify-content-center">

<div class="col-md-7">

<div class="card shadow">

<div class="card-header bg-warning">

<h3>Edit Location</h3>

</div>

<div class="card-body">

<form action="/trip/<%= tripId %>/edit/<%= itinerary.id %>" method="POST">


<div class="mb-3">
    <label class="form-label">Location</label>

    <div class="input-group">
        <input
            type="text"
            id="location_name"
            name="location_name"
            class="form-control"
            value="<%= itinerary.location_name %>"
            placeholder="Search for a location"
            required>

        <button
            type="button"
            class="btn btn-outline-primary"
            onclick="searchLocation()">
            Search
        </button>
    </div>

    <div id="searchResult" class="form-text mt-2"></div>
</div>

<input
type="hidden"
id="latitude"
name="latitude"
value="<%= itinerary.latitude %>">

<input
type="hidden"
id="longitude"
name="longitude"
value="<%= itinerary.longitude %>">

<div class="mb-3">

<label class="form-label">Visit Time</label>

<input
type="datetime-local"
name="visit_time"
class="form-control"
value="<%= itinerary.visit_time ? new Date(itinerary.visit_time).toISOString().slice(0,16) : '' %>">

</div>

<div class="d-flex justify-content-between">

<a href="/trip/<%= tripId %>"
class="btn btn-secondary">

Cancel

</a>

<button
type="submit"
class="btn btn-warning">

Save Changes

</button>

</div>

</form>

</div>

</div>

</div>

</div>

</div>

<script>
async function searchLocation() {

    const location = document.getElementById("location_name").value;

    if (!location) {
        alert("Please enter a location.");
        return;
    }

    const response = await fetch(
        `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(location)}`
    );

    const data = await response.json();

    if (data.length === 0) {
        document.getElementById("searchResult").innerHTML = "Location not found.";
        return;
    }

    document.getElementById("location_name").value = data[0].display_name;
    document.getElementById("latitude").value = data[0].lat;
    document.getElementById("longitude").value = data[0].lon;
    document.getElementById("searchResult").innerHTML = "✓ Location found!";
}
</script>
</body>
</html>