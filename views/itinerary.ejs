<!DOCTYPE html>
<html>

<head>
    <title><%= trip.trip_name %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary mb-1">
                <%= trip.trip_name %>
            </h2>

            <small class="text-muted">
                Manage locations for this trip
            </small>
        </div>

        <div>

            <a href="/trips" class="btn btn-secondary">
                ← Back to Trips
            </a>

            <a href="/trip/<%= trip.id %>/add" class="btn btn-primary">
                + Add Location
            </a>

            <a href="/trip/<%= trip.id %>/schedule" class="btn btn-success">
                View Schedule
            </a>

        </div>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-primary">

                    <tr>
                        <th>Location</th>
                        <th>Visit Time</th>
                        <th>Map</th>
                        <th width="180">Actions</th>
                    </tr>

                </thead>

                <tbody>

                <% if(itineraries.length === 0){ %>

                    <tr>

                        <td colspan="4" class="text-center text-muted py-4">

                            No locations added for this trip.

                        </td>

                    </tr>

                <% } else { %>

                    <% itineraries.forEach(item => { %>

                    <tr>

                        <td>

                            <strong><%= item.location_name %></strong>

                        </td>

                        <td>

                            <% if(item.visit_time){ %>

                                <%= new Date(item.visit_time).toLocaleString() %>

                            <% } else { %>

                                <span class="text-muted">

                                    Not Scheduled

                                </span>

                            <% } %>

                        </td>

                        <td>

                            <% if(item.latitude && item.longitude){ %>

                                <a
                                href="https://www.google.com/maps?q=<%= item.latitude %>,<%= item.longitude %>"
                                target="_blank"
                                class="btn btn-info btn-sm">

                                    View Map

                                </a>

                            <% } else { %>

                                <span class="text-muted">

                                    No Coordinates

                                </span>

                            <% } %>

                        </td>

                        <td>

                            <a
                            href="/trip/<%= trip.id %>/edit/<%= item.id %>"
                            class="btn btn-warning btn-sm">

                                Edit

                            </a>

                            <form
                            action="/trip/<%= trip.id %>/delete/<%= item.id %>"
                            method="POST"
                            class="d-inline">

                                <button
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Delete this location?')">

                                    Delete

                                </button>

                            </form>

                        </td>

                    </tr>

                    <% }) %>

                <% } %>

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>

</html>