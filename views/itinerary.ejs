<!DOCTYPE html>
<html>
<head>
    <title>My Itinerary</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:120px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            My Itinerary
        </h2>

        <a href="/itinerary/add" class="btn btn-primary">
            + Add Location
        </a>

        <a href="/itinerary/schedule" class="btn btn-success">
            View Schedule
        </a>
    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-primary">

                    <tr>
                        <th>Location</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th>Visit Time</th>
                        <th width="180">Actions</th>
                    </tr>

                </thead>

                <tbody>

                <% if(itineraries.length===0){ %>

                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No itinerary yet.
                        </td>
                    </tr>

                <% } %>

                <% itineraries.forEach(item=>{ %>

                <tr>

                    <td>
                        <strong><%= item.location_name %></strong>
                    </td>

                    <td><%= item.latitude %></td>

                    <td><%= item.longitude %></td>

                    <td>
                        <%= new Date(item.visit_time).toLocaleString() %>
                    </td>

                    <td>

                        <a href="/itinerary/edit/<%= item.id %>"
                            class="btn btn-warning btn-sm">

                            Edit

                        </a>

                        <form
                            action="/itinerary/delete/<%= item.id %>"
                            method="POST"
                            class="d-inline">

                            <button class="btn btn-danger btn-sm"
                            onclick="return confirm('Delete this location?')">

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

</body>
</html>