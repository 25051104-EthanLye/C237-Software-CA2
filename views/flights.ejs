<!DOCTYPE html>
<html>
<head>
    <title>Flights | VividVoyage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body{ background:#f4f7fb; }
        .page-title{ font-weight:700; color:#99BDBC; margin-bottom:5px; }
        .page-subtitle{ color:#6c757d; margin-bottom:0; }
        .search-box{ border-radius:30px; padding:14px 20px; box-shadow:0 5px 18px rgba(0,0,0,.08); border:none; }
        .flight-card{ transition:.3s; }
        .flight-card:hover{ transform:translateY(-8px); }
        .flight-card .card{ border:none; border-radius:20px; overflow:hidden; box-shadow:0 8px 25px rgba(0,0,0,.08); transition:.3s; }
        .flight-card .card:hover{ box-shadow:0 18px 40px rgba(0,0,0,.16); }
    </style>
</head>
<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container py-5" style="margin-top:100px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">✈️ Available Flights</h2>
            <p class="page-subtitle">Book your next flight in seconds.</p>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-5">
            <input type="text" id="flightSearch" class="form-control form-control-lg search-box" placeholder="🔍 Search by destination...">
        </div>
    </div>

    <div class="row">

    <% if(flights.length === 0){ %>
        <div class="col-12">
            <div class="card border-0 shadow text-center p-5 rounded-4">
                <div style="font-size:70px;">✈️</div>
                <h3 class="mt-3 fw-bold">No Flights Available</h3>
                <p class="text-muted">Please check back later.</p>
            </div>
        </div>
    <% } %>

    <% flights.forEach(flight => { %>
        <div class="col-xl-4 col-lg-6 mb-4 flight-card">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h4 class="fw-bold mb-1"><%= flight.flight_number %></h4>
                            <div class="text-muted">To <%= flight.destination %></div>
                        </div>
                        <div style="font-size:2.5rem;">🛫</div>
                    </div>
                    <hr>
                    <div class="mb-2"><strong>Date:</strong> <%= new Date(flight.departure_date).toLocaleDateString() %></div>
                    <div class="mb-2"><strong>Time:</strong> <%= flight.departure_time %></div>
                    <div class="mb-2"><strong>Duration:</strong> <%= flight.duration %></div>
                    <div class="mb-3" style="font-size:1.4rem; color:#99BDBC; font-weight:800;">
                        $<%= Number(flight.price).toFixed(2) %>
                    </div>

                    <% if (user) { %>
                        <a href="/flights/book/<%= flight.id %>" class="btn btn-primary w-100 rounded-pill">Book Flight</a>
                    <% } else { %>
                        <button class="btn btn-secondary w-100 rounded-pill" onclick="openLoginModal()">Sign In to Book</button>
                    <% } %>
                </div>
            </div>
        </div>
    <% }) %>

    </div>
</div>

<script>
const search = document.getElementById("flightSearch");
search.addEventListener("keyup", function(){
    const value = this.value.toLowerCase();
    document.querySelectorAll(".flight-card").forEach(card=>{
        const text = card.innerText.toLowerCase();
        card.style.display = text.includes(value) ? "block" : "none";
    });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>