<% 
    // Safely load server variables to prevent EJS crashes
    const activeUser = typeof user !== 'undefined' && user ? user : null;
    const loginErrors = typeof errors !== 'undefined' ? errors : [];
    const successMsgs = typeof messages !== 'undefined' ? messages : [];
%>

<!-- FIX 1: Load Bootstrap 5 for automatic responsiveness and dropdown bounds management -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    /* Profile Button Styling (Kept your custom aesthetic) */
    .profile-btn {
        display: flex; align-items: center; gap: 12px;
        background: var(--light-bg); border: 2px solid var(--teal);
        padding: 5px 15px 5px 5px; border-radius: 40px; cursor: pointer; transition: all 0.3s;
    }
    .profile-btn:hover { background: var(--white); box-shadow: 0 5px 15px rgba(153, 189, 188, 0.3); }
    
    .profile-pic { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
    .profile-name { color: var(--teal); font-weight: 800; font-size: 16px; }

    /* Customizing Bootstrap Nav Links */
    .nav-link-custom {
        color: #99BDBC !important; text-decoration: none; font-weight: 800; font-size: 16px; transition: color 0.2s;
    }
    .nav-link-custom:hover { color: var(--dark-text) !important; } 

    /* Modal Styles */
    .modal-overlay {
        display: none; position: fixed; z-index: 9999; left: 0; top: 0;
        width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); 
        backdrop-filter: blur(5px); align-items: center; justify-content: center;
    }

    .modal-card {
        background-color: var(--white); padding: 40px; border-radius: 20px;
        box-shadow: 0 10px 30px rgba(153, 189, 188, 0.4); border: 1px solid rgba(162, 191, 206, 0.3);
        width: 90%; max-width: 450px; text-align: center; position: relative; 
        animation: dropIn 0.3s ease-out forwards;
    }
    @keyframes dropIn { from { transform: translateY(-50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .close-btn { position: absolute; top: 15px; right: 20px; font-size: 28px; font-weight: 800; color: var(--blue); cursor: pointer; transition: color 0.3s; }
    .close-btn:hover { color: var(--teal); }
</style>

<!-- Main Navigation Bar (Rebuilt with Bootstrap) -->
<nav class="navbar navbar-expand-lg bg-white sticky-top py-3 px-3 px-lg-5" style="box-shadow: 0 4px 15px rgba(162, 191, 206, 0.2);">
    <div class="container-fluid p-0">
        
        <a class="navbar-brand" href="/" style="font-size: 28px; font-weight: 800; color: var(--teal);">VividVoyage</a>
        
        <!-- Mobile Toggle Button -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#vividNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse justify-content-between" id="vividNav">
            
            <!-- Centered Links -->
            <ul class="navbar-nav mx-auto gap-lg-4 mb-3 mb-lg-0 mt-3 mt-lg-0 text-center">
                <li class="nav-item"><a class="nav-link nav-link-custom" href="/flights">Flights</a></li>
                <li class="nav-item"><a class="nav-link nav-link-custom" href="/hotels">Hotels</a></li>
                <li class="nav-item"><a class="nav-link nav-link-custom" href="/trips">Itinerary</a></li>
            </ul>
            
            <!-- Right side Auth -->
            <div class="d-flex align-items-center justify-content-center gap-3">
                <% if (activeUser) { %>
                    <!-- FIX 1 (cont): dropdown-menu-end forces the menu to drop inside the screen bounds -->
                    <div class="dropdown">
                        <div class="profile-btn" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            
                            <!-- DYNAMIC PROFILE PICTURE LOGIC -->
                            <% if (activeUser.profile_picture) { %>
                                <!-- Removed /uploads/ prefix so it successfully renders the database Base64 text -->
                                <img src="<%= activeUser.profile_picture %>" alt="Profile" class="profile-pic">
                            <% } else { %>
                                <img src="https://ui-avatars.com/api/?name=<%= activeUser.username %>&background=99BDBC&color=fff&bold=true" alt="Profile" class="profile-pic">
                            <% } %>

                            <span class="profile-name"><%= activeUser.username %></span>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-2" style="border-radius: 15px; border: 1px solid rgba(162, 191, 206, 0.2); min-width: 200px;">
                            <li><a class="dropdown-item fw-bold py-2 rounded-3" href="/profile" style="color: var(--dark-text);">Profile Overview</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item fw-bold py-2 rounded-3 text-danger" href="/logout">Sign Out</a></li>
                        </ul>
                    </div>

                <% } else { %>
                    <button onclick="openLoginModal()" class="btn" style="background: rgba(255,255,255,0.9); color: var(--teal); border: 2px solid var(--teal); padding: 10px 25px; border-radius: 30px; font-weight: 800; cursor: pointer;">Sign In</button>
                    <a href="/register" class="btn btn-register" style="padding: 12px 25px; border-radius: 30px; text-decoration: none; font-weight: 800;">Register Now</a>
                <% } %>
            </div>

        </div>
    </div>
</nav>

<!-- Hidden Login Modal -->
<div id="loginModal" class="modal-overlay">
    <div class="modal-card">
        <span class="close-btn" onclick="closeLoginModal()">&times;</span>
        <h1 style="color: var(--teal); font-size: 32px; font-weight: 800; margin-bottom: 10px;">Welcome Back</h1>
        <p style="color: #888; margin-bottom: 25px;">Sign in to continue your journey.</p>

        <% if (loginErrors.length > 0) { %>
            <div style="background-color: #ffe6e6; color: #cc0000; padding: 15px; border-radius: 10px; margin-bottom: 20px; font-weight: 600; font-size: 14px;">
                <% loginErrors.forEach(function(error) { %> <p class="mb-0"><%= error %></p> <% }); %>
            </div>
        <% } %>

        <% if (successMsgs.length > 0) { %>
            <div style="background-color: #e6ffed; color: #009933; padding: 15px; border-radius: 10px; margin-bottom: 20px; font-weight: 600; font-size: 14px;">
                <% successMsgs.forEach(function(msg) { %> <p class="mb-0"><%= msg %></p> <% }); %>
            </div>
        <% } %>

        <form action="/login" method="POST" style="text-align: left;">
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-size: 14px; color: var(--teal); font-weight: 800; margin-bottom: 8px; text-transform: uppercase;">Username</label>
                <input type="text" name="username" placeholder="Enter your username" required style="width: 100%; padding: 14px; border: 2px solid var(--blue); border-radius: 12px; font-size: 16px; outline: none; color: var(--dark-text);">
            </div>
            
            <div style="margin-bottom: 25px;">
                <label style="display: block; font-size: 14px; color: var(--teal); font-weight: 800; margin-bottom: 8px; text-transform: uppercase;">Password</label>
                <input type="password" name="password" placeholder="Enter your password" required style="width: 100%; padding: 14px; border: 2px solid var(--blue); border-radius: 12px; font-size: 16px; outline: none; color: var(--dark-text);">
            </div>
            
            <button type="submit" class="btn btn-register" style="width: 100%; padding: 14px; font-size: 18px; border-radius: 30px; border: none; cursor: pointer; background-color: var(--peach); color: white; font-weight: 800;">Sign In</button>
        </form>
    </div>
</div>

<!-- Load Bootstrap JS to enable the Dropdown and Mobile Menu to function -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- Modal Logic Script -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loginModalElement = document.getElementById('loginModal');

        // Show/Hide Login
        window.openLoginModal = function() { if (loginModalElement) loginModalElement.style.display = 'flex'; };
        window.closeLoginModal = function() { if (loginModalElement) loginModalElement.style.display = 'none'; };

        // Click off to close
        window.onclick = function(event) {
            if (event.target === loginModalElement) closeLoginModal();
        };

        // Decides if the modal should automatically pop open based on server messages
        const shouldOpenModal = <%= (loginErrors.length > 0 || successMsgs.length > 0) ? 'true' : 'false' %>;
        if (shouldOpenModal) {
            setTimeout(() => { openLoginModal(); }, 100);
        }
    });
</script>