<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moderate Reviews | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
        .stars { color: #E2C1AA; letter-spacing: 2px; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/admin" class="text-decoration-none text-brand fw-bold">&larr; Back to Dashboard</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">⭐ Moderate Reviews</h1>
            <p class="text-muted">Review what travelers are saying and remove anything inappropriate.</p>
        </div>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title mb-3">All Reviews (<%= reviews.length %>)</h4>
                <% if (reviews.length === 0) { %>
                    <p class="text-muted mb-0">No reviews submitted yet.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>From</th>
                                    <th>Destination</th>
                                    <th>Rating</th>
                                    <th>Comment</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% reviews.forEach(r => { %>
                                    <tr>
                                        <td>#<%= r.id %></td>
                                        <td><%= r.username || 'Unknown user' %></td>
                                        <td><%= r.destination %></td>
                                        <td class="stars"><%= '★'.repeat(r.rating) %><span style="color:#ddd;"><%= '★'.repeat(5 - r.rating) %></span></td>
                                        <td><%= r.text %></td>
                                        <td class="text-end">
                                            <form action="/admin/reviews/delete/<%= r.id %>" method="POST" onsubmit="return confirm('Remove this review?');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>