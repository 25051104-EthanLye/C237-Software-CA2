<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Hotels | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
        .btn.btn-brand { background-color: #E8895C; border: none; color: #fff; font-weight: 800; transition: transform 0.15s ease, box-shadow 0.15s ease; }
        .btn.btn-brand:hover { background-color: #d6763f; color: #fff; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(232, 137, 92, 0.5); }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/admin" class="text-decoration-none text-brand fw-bold">&larr; Back to Dashboard</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">🏨 Hotel Inventory Management</h1>
            <p class="text-muted">Add new hotels, edit existing ones, or remove ones no longer offered.</p>
        </div>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <!-- Add Hotel Form -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h4 class="card-title mb-3">Add New Hotel</h4>
                <form action="/admin/hotels/add" method="POST" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Hotel Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Shibuya Grand Hotel" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Location</label>
                        <input type="text" name="location" class="form-control" placeholder="e.g. Tokyo, Japan" required>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Price / Night ($)</label>
                        <input type="number" step="0.01" min="0" name="price_per_night" class="form-control" placeholder="120.00" required>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-brand w-100">+ Add Hotel</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Hotel List -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title mb-3">Current Inventory (<%= hotels.length %>)</h4>
                <% if (hotels.length === 0) { %>
                    <p class="text-muted mb-0">No hotels added yet. Use the form above to add your first one.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Location</th>
                                    <th>Price / Night</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% hotels.forEach(hotel => { %>
                                    <tr>
                                        <td>#<%= hotel.id %></td>
                                        <td><%= hotel.name %></td>
                                        <td><%= hotel.location %></td>
                                        <td>$<%= Number(hotel.price_per_night).toFixed(2) %></td>
                                        <td class="text-end">
                                            <a href="/admin/hotels/edit/<%= hotel.id %>" class="btn btn-outline-success btn-sm">Edit</a>
                                            <form action="/admin/hotels/delete/<%= hotel.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this hotel from inventory?');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>