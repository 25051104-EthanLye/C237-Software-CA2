<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
        .admin-card { transition: transform 0.2s ease, box-shadow 0.2s ease; text-decoration: none; height: 100%; }
        .admin-card:hover { transform: translateY(-6px); box-shadow: 0 10px 25px rgba(153, 189, 188, 0.3) !important; }
        .admin-card .icon { font-size: 38px; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/" class="text-decoration-none text-brand fw-bold">&larr; Back to Home</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">🛠️ Admin Control Panel</h1>
            <p class="text-muted">Manage inventory, moderate reviews, and manage user accounts from one place.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <a href="/admin/hotels" class="card admin-card shadow-sm border-0 p-4 text-center">
                    <div class="icon mb-2">🏨</div>
                    <h5 class="fw-bold text-dark">Hotel Inventory</h5>
                    <p class="text-muted small mb-0">Add, edit, and remove hotels.</p>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="/admin/flights" class="card admin-card shadow-sm border-0 p-4 text-center">
                    <div class="icon mb-2">✈️</div>
                    <h5 class="fw-bold text-dark">Flight Inventory</h5>
                    <p class="text-muted small mb-0">Add, edit, and remove flight routes.</p>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="/admin/reviews" class="card admin-card shadow-sm border-0 p-4 text-center">
                    <div class="icon mb-2">⭐</div>
                    <h5 class="fw-bold text-dark">Moderate Reviews</h5>
                    <p class="text-muted small mb-0">View and remove bad reviews.</p>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="/admin/users" class="card admin-card shadow-sm border-0 p-4 text-center">
                    <div class="icon mb-2">👤</div>
                    <h5 class="fw-bold text-dark">Manage Users</h5>
                    <p class="text-muted small mb-0">Ban or unban user accounts.</p>
                </a>
            </div>
        </div>
    </div>

</body>
</html>