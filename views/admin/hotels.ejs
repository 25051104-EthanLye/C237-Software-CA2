<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Hotels | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background-color: var(--light-bg); }
        .page-header { padding: 40px 0 20px 0; }
        .page-header h1 { color: var(--teal); font-weight: 800; }
        .panel {
            background: var(--white);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15);
            border: 1px solid rgba(162, 191, 206, 0.2);
            margin-bottom: 30px;
        }
        .panel h4 { color: var(--dark-text); font-weight: 800; margin-bottom: 20px; }
        .btn-brand {
            background-color: var(--teal);
            color: var(--white);
            border: none;
            font-weight: 800;
            border-radius: 30px;
            padding: 10px 30px;
        }
        .btn-brand:hover { background-color: #7fa5a4; color: var(--white); }
        table th { color: var(--teal); font-weight: 800; }
        .btn-del { border-radius: 20px; font-weight: 700; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="page-header">
            <h1>🏨 Hotel Inventory Management</h1>
            <p class="text-muted">Add new hotels, or remove ones no longer offered.</p>
        </div>

        <!-- Flash Messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <!-- Add Hotel Form -->
        <div class="panel">
            <h4>Add New Hotel</h4>
            <form action="/admin/hotels/add" method="POST" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Hotel Name</label>
                    <input type="text" name="name" class="form-control" placeholder="e.g. Shibuya Grand Hotel" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" placeholder="e.g. Tokyo, Japan" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Price / Night ($)</label>
                    <input type="number" step="0.01" min="0" name="price_per_night" class="form-control" placeholder="120.00" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-brand w-100">+ Add Hotel</button>
                </div>
            </form>
        </div>

        <!-- Hotel List -->
        <div class="panel">
            <h4>Current Inventory (<%= hotels.length %>)</h4>
            <% if (hotels.length === 0) { %>
                <p class="text-muted mb-0">No hotels added yet. Use the form above to add your first one.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Location</th>
                                <th>Price / Night</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% hotels.forEach(hotel => { %>
                                <tr>
                                    <td>#<%= hotel.id %></td>
                                    <td><%= hotel.name %></td>
                                    <td><%= hotel.location %></td>
                                    <td>$<%= Number(hotel.price_per_night).toFixed(2) %></td>
                                    <td class="text-end">
                                        <form action="/admin/hotels/delete/<%= hotel.id %>" method="POST" onsubmit="return confirm('Delete this hotel from inventory?');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm btn-del">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>