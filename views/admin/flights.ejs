<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Flights | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background-color: var(--light-bg); }
        .page-header { padding: 40px 0 20px 0; }
        .page-header h1 { color: var(--teal); font-weight: 800; }
        .panel {
            background: var(--white);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15);
            border: 1px solid rgba(162, 191, 206, 0.2);
            margin-bottom: 30px;
        }
        .panel h4 { color: var(--dark-text); font-weight: 800; margin-bottom: 20px; }
        .btn-brand {
            background-color: var(--teal);
            color: var(--white);
            border: none;
            font-weight: 800;
            border-radius: 30px;
            padding: 10px 30px;
        }
        .btn-brand:hover { background-color: #7fa5a4; color: var(--white); }
        table th { color: var(--teal); font-weight: 800; }
        .btn-del { border-radius: 20px; font-weight: 700; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="page-header">
            <h1>✈️ Flight Inventory Management</h1>
            <p class="text-muted">Add new flight routes, or remove ones no longer offered.</p>
        </div>

        <!-- Flash Messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <!-- Add Flight Form -->
        <div class="panel">
            <h4>Add New Flight Route</h4>
            <form action="/admin/flights/add" method="POST" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Flight Number</label>
                    <input type="text" name="flight_number" class="form-control" placeholder="e.g. SQ638" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Destination</label>
                    <input type="text" name="destination" class="form-control" placeholder="e.g. Tokyo" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Departure Date</label>
                    <input type="date" name="departure_date" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Departure Time</label>
                    <input type="time" name="departure_time" class="form-control" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Duration</label>
                    <input type="text" name="duration" class="form-control" placeholder="e.g. 7h 10m" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Price ($)</label>
                    <input type="number" step="0.01" min="0" name="price" class="form-control" placeholder="450.00" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-brand w-100">+ Add Flight</button>
                </div>
            </form>
        </div>

        <!-- Flight List -->
        <div class="panel">
            <h4>Current Inventory (<%= flights.length %>)</h4>
            <% if (flights.length === 0) { %>
                <p class="text-muted mb-0">No flights added yet. Use the form above to add your first one.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Flight No.</th>
                                <th>Destination</th>
                                <th>Departure</th>
                                <th>Duration</th>
                                <th>Price</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% flights.forEach(flight => { %>
                                <tr>
                                    <td>#<%= flight.id %></td>
                                    <td><%= flight.flight_number %></td>
                                    <td>Singapore &rarr; <%= flight.destination %></td>
                                    <td><%= flight.departure_date %> @ <%= flight.departure_time %></td>
                                    <td><%= flight.duration %></td>
                                    <td>$<%= Number(flight.price).toFixed(2) %></td>
                                    <td class="text-end">
                                        <form action="/admin/flights/delete/<%= flight.id %>" method="POST" onsubmit="return confirm('Delete this flight route from inventory?');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm btn-del">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>