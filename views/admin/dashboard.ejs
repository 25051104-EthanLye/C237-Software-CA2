<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background-color: var(--light-bg); }
        .admin-header { padding: 50px 0 30px 0; }
        .admin-header h1 { color: var(--teal); font-weight: 800; }
        .admin-header p { color: #888; }
        .admin-card {
            background: var(--white);
            border-radius: 20px;
            padding: 35px;
            text-decoration: none;
            display: block;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15);
            border: 1px solid rgba(162, 191, 206, 0.2);
            transition: transform 0.3s ease;
            height: 100%;
        }
        .admin-card:hover { transform: translateY(-8px); box-shadow: 0 8px 25px rgba(162, 191, 206, 0.3); }
        .admin-card .icon { font-size: 40px; margin-bottom: 15px; }
        .admin-card h3 { color: var(--dark-text); font-weight: 800; margin-bottom: 8px; }
        .admin-card p { color: #888; margin-bottom: 0; font-size: 15px; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container admin-header">
        <h1>🛠️ Admin Control Panel</h1>
        <p>Manage inventory and moderate reviews from one place.</p>
    </div>

    <div class="container pb-5">
        <div class="row g-4">
            <div class="col-md-4">
                <a href="/admin/hotels" class="admin-card">
                    <div class="icon">🏨</div>
                    <h3>Hotel Inventory</h3>
                    <p>Add, view, and remove hotels available on the platform.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/admin/flights" class="admin-card">
                    <div class="icon">✈️</div>
                    <h3>Flight Inventory</h3>
                    <p>Add, view, and remove flight routes available for booking.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/admin/reviews" class="admin-card">
                    <div class="icon">⭐</div>
                    <h3>Moderate Reviews</h3>
                    <p>View all traveler reviews and remove anything inappropriate.</p>
                </a>
            </div>
        </div>
    </div>

</body>
</html>