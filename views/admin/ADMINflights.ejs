<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Flights | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
        .btn.btn-brand { background-color: #E8895C; border: none; color: #fff; font-weight: 800; transition: transform 0.15s ease, box-shadow 0.15s ease; }
        .btn.btn-brand:hover { background-color: #d6763f; color: #fff; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(232, 137, 92, 0.5); }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/admin" class="text-decoration-none text-brand fw-bold">&larr; Back to Dashboard</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">✈️ Flight Inventory Management</h1>
            <p class="text-muted">Add new flight routes, edit existing ones, or remove ones no longer offered.</p>
        </div>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <!-- Add Flight Form -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h4 class="card-title mb-3">Add New Flight Route</h4>
                <form action="/admin/flights/add" method="POST" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Flight Number</label>
                        <input type="text" name="flight_number" class="form-control" placeholder="e.g. SQ638" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Destination</label>
                        <input type="text" name="destination" class="form-control" placeholder="e.g. Tokyo" required>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Departure Date</label>
                        <input type="date" name="departure_date" class="form-control" required>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Departure Time</label>
                        <input type="time" name="departure_time" class="form-control" required>
                    </div>
                    <div class="col-md-1">
                        <label class="form-label fw-bold">Duration</label>
                        <input type="text" name="duration" class="form-control" placeholder="7h 10m" required>
                    </div>
                    <div class="col-md-1">
                        <label class="form-label fw-bold">Price ($)</label>
                        <input type="number" step="0.01" min="0" name="price" class="form-control" placeholder="450" required>
                    </div>
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-brand px-4">+ Add Flight</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Flight List -->
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title mb-3">Current Inventory (<%= flights.length %>)</h4>
                <% if (flights.length === 0) { %>
                    <p class="text-muted mb-0">No flights added yet. Use the form above to add your first one.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Flight No.</th>
                                    <th>Destination</th>
                                    <th>Departure</th>
                                    <th>Duration</th>
                                    <th>Price</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% flights.forEach(flight => { %>
                                    <tr>
                                        <td>#<%= flight.id %></td>
                                        <td><%= flight.flight_number %></td>
                                        <td>Singapore &rarr; <%= flight.destination %></td>
                                        <td><%= flight.departure_date instanceof Date ? flight.departure_date.toISOString().split('T')[0] : flight.departure_date %> @ <%= flight.departure_time %></td>
                                        <td><%= flight.duration %></td>
                                        <td>$<%= Number(flight.price).toFixed(2) %></td>
                                        <td class="text-end">
                                            <a href="/admin/flights/edit/<%= flight.id %>" class="btn btn-outline-success btn-sm">Edit</a>
                                            <form action="/admin/flights/delete/<%= flight.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this flight route from inventory?');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>