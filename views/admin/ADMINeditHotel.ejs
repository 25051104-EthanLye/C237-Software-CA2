<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Hotel | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
        .btn.btn-brand { background-color: #E8895C; border: none; color: #fff; font-weight: 800; }
        .btn.btn-brand:hover { background-color: #d6763f; color: #fff; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/admin/hotels" class="text-decoration-none text-brand fw-bold">&larr; Back to Hotel Inventory</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">✏️ Edit Hotel</h1>
            <p class="text-muted">Update the details for this hotel listing.</p>
        </div>

        <div class="card shadow-sm border-0" style="max-width: 600px;">
            <div class="card-body">
                <form action="/admin/hotels/edit/<%= hotel.id %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Hotel Name</label>
                        <input type="text" name="name" class="form-control" value="<%= hotel.name %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Location</label>
                        <input type="text" name="location" class="form-control" value="<%= hotel.location %>" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Price / Night ($)</label>
                        <input type="number" step="0.01" min="0" name="price_per_night" class="form-control" value="<%= hotel.price_per_night %>" required>
                    </div>
                    <button type="submit" class="btn btn-brand w-100 py-2">Save Changes</button>
                </form>
            </div>
        </div>
    </div>

</body>
</html>