<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; background-color: #F8F9FA; }
        h1, h4 { font-weight: 800; }
        .text-brand { color: #99BDBC; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container py-4">

        <a href="/admin" class="text-decoration-none text-brand fw-bold">&larr; Back to Dashboard</a>

        <div class="mb-4 mt-2">
            <h1 class="text-brand">👤 Manage Users</h1>
            <p class="text-muted">Ban accounts that are misusing the platform, or unban them if needed.</p>
        </div>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title mb-3">All Users (<%= users.length %>)</h4>

                <% if (users.length === 0) { %>
                    <p class="text-muted mb-0">No users registered yet.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                    <tr>
                                        <td>#<%= u.id %></td>
                                        <td><%= u.username %></td>
                                        <td><%= u.email %></td>
                                        <td><span class="badge bg-secondary"><%= u.role %></span></td>
                                        <td>
                                            <% if (u.account_status === 'suspended') { %>
                                                <span class="badge bg-danger">Suspended</span>
                                            <% } else { %>
                                                <span class="badge bg-success">Active</span>
                                            <% } %>
                                        </td>
                                        <td class="text-end">
                                            <% if (u.role === 'admin') { %>
                                                <span class="text-muted small">—</span>
                                            <% } else if (u.account_status === 'suspended') { %>
                                                <form action="/admin/users/unban/<%= u.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-success btn-sm">Unban</button>
                                                </form>
                                            <% } else { %>
                                                <form action="/admin/users/ban/<%= u.id %>" method="POST" class="d-inline" onsubmit="return confirm('Ban this user? They will be logged out and unable to sign in.');">
                                                    <button type="submit" class="btn btn-danger btn-sm">Ban</button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>