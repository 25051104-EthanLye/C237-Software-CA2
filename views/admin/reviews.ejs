<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moderate Reviews | VividVoyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }
        * { font-family: 'Nunito', sans-serif; }
        body { background-color: var(--light-bg); }
        .page-header { padding: 40px 0 20px 0; }
        .page-header h1 { color: var(--teal); font-weight: 800; }
        .panel {
            background: var(--white);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15);
            border: 1px solid rgba(162, 191, 206, 0.2);
            margin-bottom: 30px;
        }
        table th { color: var(--teal); font-weight: 800; }
        .stars { color: var(--peach); letter-spacing: 2px; }
        .btn-del { border-radius: 20px; font-weight: 700; }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="container">
        <div class="page-header">
            <h1>⭐ Moderate Reviews</h1>
            <p class="text-muted">Review what travelers are saying and remove anything inappropriate.</p>
        </div>

        <!-- Flash Messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success"><% messages.forEach(m => { %><p class="mb-0"><%= m %></p><% }) %></div>
        <% } %>
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><% errors.forEach(e => { %><p class="mb-0"><%= e %></p><% }) %></div>
        <% } %>

        <div class="panel">
            <h4 class="mb-3" style="color:var(--dark-text); font-weight:800;">All Reviews (<%= reviews.length %>)</h4>
            <% if (reviews.length === 0) { %>
                <p class="text-muted mb-0">No reviews submitted yet.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>From</th>
                                <th>Destination</th>
                                <th>Rating</th>
                                <th>Comment</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviews.forEach(r => { %>
                                <tr>
                                    <td>#<%= r.id %></td>
                                    <td><%= r.username || 'Unknown user' %></td>
                                    <td><%= r.target_destination %></td>
                                    <td class="stars"><%= '★'.repeat(r.rating) %><span style="color:#ddd;"><%= '★'.repeat(5 - r.rating) %></span></td>
                                    <td><%= r.comment %></td>
                                    <td class="text-end">
                                        <form action="/admin/reviews/delete/<%= r.id %>" method="POST" onsubmit="return confirm('Remove this review?');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm btn-del">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>