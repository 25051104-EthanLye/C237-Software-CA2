<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VividVoyage - Travel the World</title>
    <!-- Using Nunito for a warm, rounded, and highly readable aesthetic -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* --- COLOR SCHEME & VARIABLES --- */
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Nunito', sans-serif;
        }

        body {
            background-color: var(--white);
            color: var(--dark-text);
        }

        /* --- BUTTON STYLES (Used for the Hero Section) --- */
        .btn {
            padding: 12px 28px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            border-radius: 30px;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            display: inline-block;
        }

        .btn-register {
            background-color: var(--peach);
            color: var(--white);
            box-shadow: 0 4px 15px rgba(226, 193, 170, 0.5);
        }

        .btn-register:hover {
            background-color: #d1b099;
            transform: translateY(-2px);
        }

        /* --- HERO CAROUSEL SECTION --- */
        .hero {
            position: relative;
            /* Adjusted slightly so it looks perfect under the new white navbar */
            height: calc(100vh - 75px); 
            width: 100%;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        /* The background image containers now animate opacity */
        .carousel-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: opacity 1.5s ease-in-out; 
            z-index: 1;
            opacity: 0; 
        }

        /* This class makes the currently active layer visible */
        .carousel-bg.active {
            opacity: 1; 
        }

        /* Dark overlay to make text readable */
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.1));
            z-index: 2;
        }

        .hero-content {
            position: relative;
            z-index: 3;
            color: var(--white);
            padding: 0 20px;
        }

        .hero-content h1 {
            font-size: 56px;
            font-weight: 800;
            margin-bottom: 15px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
        }

        .hero-content p {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 30px;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
        }

        /* --- FEATURES SECTION --- */
        .features-section {
            padding: 80px 50px;
            background-color: var(--white);
            text-align: center;
        }

        .features-section h2 {
            font-size: 36px;
            color: var(--teal);
            margin-bottom: 50px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .feature-card {
            background-color: var(--white);
            padding: 40px 20px;
            border-radius: 25px; 
            box-shadow: 0 10px 30px rgba(162, 191, 206, 0.2); 
            transition: transform 0.3s ease;
            border: 1px solid rgba(162, 191, 206, 0.3);
        }

        .feature-card:hover {
            transform: translateY(-10px);
        }

        .feature-card .icon {
            width: 70px;
            height: 70px;
            background-color: var(--blue);
            color: var(--white);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 20px auto;
        }

        .feature-card h3 {
            color: var(--teal);
            margin-bottom: 15px;
            font-size: 22px;
        }

        .feature-card p {
            color: #666;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <!-- Inject the navigation bar here -->
    <%- include('partials/navbar') %>

    <!-- Hero Carousel -->
    <section class="hero">
        <!-- Two separate layers for the cross-fade effect. Layer 1 starts active. -->
        <div class="carousel-bg active" id="carousel-layer-1"></div>
        <div class="carousel-bg" id="carousel-layer-2"></div>
        <div class="overlay"></div>
        <div class="hero-content">
            <h1>Discover the Extraordinary</h1>
            <p>Your journey begins here. Plan, book, and explore.</p>
            <a href="/register" class="btn btn-register" style="font-size: 18px; padding: 15px 40px;">Start Exploring</a>
        </div>
    </section>

    <!-- Features Showcase -->
    <section class="features-section">
        <h2>Everything You Need in One Place</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="icon" style="background-color: var(--teal);">✈️</div>
                <h3>Flight Bookings</h3>
                <p>Search and book simulated flights to your dream destinations instantly.</p>
            </div>
            <div class="feature-card">
                <div class="icon" style="background-color: var(--peach);">🏨</div>
                <h3>Hotel Stays</h3>
                <p>Find the perfect accommodation with smooth, easy-to-manage reservations.</p>
            </div>
            <div class="feature-card">
                <div class="icon" style="background-color: var(--blue);">🗺️</div>
                <h3>Smart Itineraries</h3>
                <p>Pinpoint your favorite spots on a functional map and build your daily schedule.</p>
            </div>
            <div class="feature-card">
                <div class="icon" style="background-color: var(--teal);">⭐</div>
                <h3>Travel Reviews</h3>
                <p>Share your experiences and read real stories from fellow travelers.</p>
            </div>
        </div>
    </section>

    <!-- Vanilla JS for the Randomized Carousel -->
    <script>
        // Adjusted array with fresh links (optimized to 1920px for fast loading), including bird's eye Tokyo
        const images = [
            'https://images.unsplash.com/photo-1483347756197-71ef80e95f73?auto=format&fit=crop&w=1920&q=80', // Northern Lights
            'https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?auto=format&fit=crop&w=1920&q=80', // Pyramid of Giza
            'https://images.unsplash.com/photo-1536098561742-ca998e48cbcc?auto=format&fit=crop&w=1920&q=80', // Tokyo City Skyline (Bird's Eye)
            'https://images.unsplash.com/photo-1522383225653-ed111181a951?auto=format&fit=crop&w=1920&q=80', // Sakura Plants
            'https://images.unsplash.com/photo-1530122037265-a5f1f91d3b99?auto=format&fit=crop&w=1920&q=80'  // Swiss Alps
        ];

        // Preloads images in the background so there are no grey screens before the next image appears
        function preloadImages(imageArray) {
            imageArray.forEach(src => {
                const img = new Image();
                img.src = src;
            });
        }

        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        // Execute preload
        preloadImages(images);

        // Grab both layers for the cross-fade animation
        const layer1 = document.getElementById('carousel-layer-1');
        const layer2 = document.getElementById('carousel-layer-2');
        const randomizedImages = shuffleArray([...images]);
        
        let currentIndex = 0;
        let showingLayer1 = true;

        // Set the first image immediately on Layer 1
        layer1.style.backgroundImage = `url('${randomizedImages[currentIndex]}')`;

        // Change image every 5 seconds with a smooth cross-fade
        setInterval(() => {
            currentIndex = (currentIndex + 1) % randomizedImages.length;
            const nextImage = `url('${randomizedImages[currentIndex]}')`;

            // Alternates loading the new image into the hidden layer, then toggles the .active class to fade it in
            if (showingLayer1) {
                layer2.style.backgroundImage = nextImage;
                layer2.classList.add('active');
                layer1.classList.remove('active');
            } else {
                layer1.style.backgroundImage = nextImage;
                layer1.classList.add('active');
                layer2.classList.remove('active');
            }
            
            showingLayer1 = !showingLayer1;
            
        }, 5000); 
    </script>
</body>
</html>