<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VividVoyage - Travel the World</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        /* --- COLOR SCHEME & VARIABLES --- */
        :root {
            --white: #FFFFFF;
            --peach: #E2C1AA;
            --teal: #99BDBC;
            --blue: #A2BFCE;
            --dark-text: #2C3E50;
            --light-bg: #F8F9FA;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Nunito', sans-serif;
        }

        body {
            background-color: var(--white);
            color: var(--dark-text);
        }

        /* --- BUTTON STYLES --- */
        .btn {
            padding: 12px 28px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            border-radius: 30px;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            display: inline-block;
        }

        .btn-register {
            background-color: var(--peach);
            color: var(--white);
            box-shadow: 0 4px 15px rgba(226, 193, 170, 0.5);
        }

        .btn-register:hover {
            background-color: #d1b099;
            transform: translateY(-2px);
        }

        /* --- HERO CAROUSEL SECTION --- */
        .hero {
            position: relative;
            height: 60vh;
            min-height: 400px;
            width: 100%;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        .carousel-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: opacity 1.5s ease-in-out; 
            z-index: 1;
            opacity: 0; 
        }

        .carousel-bg.active {
            opacity: 1; 
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.2));
            z-index: 2;
        }

        .hero-content {
            position: relative;
            z-index: 3;
            color: var(--white);
            text-align: center;
            margin-bottom: 40px;
        }

        .hero-content h1 {
            font-size: 50px;
            font-weight: 800;
            margin-bottom: 10px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
        }

        .hero-content p {
            font-size: 20px;
            font-weight: 600;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
        }

        /* --- SEARCH WIDGET --- */
        .search-widget {
            position: relative;
            z-index: 3;
            background-color: var(--white);
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            width: 90%;
            max-width: 1000px;
        }

        .search-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }

        .search-tabs button {
            background: none;
            border: none;
            font-size: 16px;
            font-weight: 600;
            color: #888;
            cursor: pointer;
            padding: 8px 16px;
            border-radius: 20px;
            transition: all 0.3s;
        }

        .search-tabs button.active {
            background-color: var(--dark-text);
            color: var(--white);
        }

        .search-form {
            display: flex;
            gap: 15px;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            text-align: left;
            flex: 1;
            min-width: 150px;
        }

        .input-group label {
            font-size: 13px;
            color: var(--teal);
            font-weight: 800;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .input-group input, .input-group select {
            padding: 12px;
            border: 1px solid var(--blue);
            border-radius: 10px;
            font-size: 15px;
            color: var(--dark-text);
            outline: none;
        }

        .search-btn {
            padding: 14px 35px;
            font-size: 18px;
            height: 100%;
            margin-top: 20px;
        }

        /* --- DISPLAY SECTIONS (FLIGHTS, HOTELS, ITINERARIES) --- */
        .data-section {
            padding: 40px 50px 80px 50px;
            background-color: var(--white);
        }

        .data-section.bg-light {
            background-color: var(--light-bg);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .section-header h2 {
            font-size: 32px;
            color: var(--teal);
        }

        .view-all {
            color: var(--blue);
            text-decoration: none;
            font-weight: 800;
        }

        .view-all:hover {
            color: var(--peach);
        }

        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Item Cards */
        .item-card {
            background-color: var(--white);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(162, 191, 206, 0.15);
            transition: transform 0.3s ease;
            border: 1px solid rgba(162, 191, 206, 0.2);
        }

        .item-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 8px 25px rgba(162, 191, 206, 0.3);
        }

        .item-img {
            height: 180px;
            width: 100%;
            background-color: var(--blue);
            background-size: cover;
            background-position: center;
        }

        .item-details {
            padding: 20px;
        }

        .item-title {
            font-size: 20px;
            color: var(--dark-text);
            margin-bottom: 5px;
            font-weight: 800;
        }

        .item-subtitle {
            color: #888;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .item-price {
            font-size: 22px;
            color: var(--teal);
            font-weight: 800;
        }

        .book-btn {
            display: block;
            text-align: center;
            margin-top: 15px;
            background-color: var(--white);
            color: var(--teal);
            border: 2px solid var(--teal);
        }

        .book-btn:hover {
            background-color: var(--teal);
            color: var(--white);
        }
    </style>
</head>
<body>

    <%- include('partials/navbar') %>

    <!-- Hero Carousel with Search Widget -->
    <section class="hero">
        <div class="carousel-bg active" id="carousel-layer-1"></div>
        <div class="carousel-bg" id="carousel-layer-2"></div>
        <div class="overlay"></div>
        
        <div class="hero-content">
            <h1>Discover the Extraordinary</h1>
            <p>Secure payments | World-class destinations | 24/7 Support</p>
        </div>

        <!-- The Interactive Search Widget -->
        <div class="search-widget">
            <div class="search-tabs">
                <button class="tab active" onclick="switchTab('flights')">✈️ Flights</button>
                <button class="tab" onclick="switchTab('hotels')">🏨 Hotels & Homes</button>
            </div>
            
            <form class="search-form" action="/search" method="GET">
                <div class="input-group">
                    <label>Where to?</label>
                    <input type="text" name="destination" placeholder="City or Airport..." required>
                </div>
                <div class="input-group">
                    <label>Departure Date</label>
                    <input type="date" name="date" required>
                </div>
                <div class="input-group">
                    <label>Travelers</label>
                    <select name="guests">
                        <option>1 Adult, 0 Children</option>
                        <option>2 Adults, 0 Children</option>
                        <option>2 Adults, 1 Child</option>
                        <option>2 Adults, 2 Children</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-register search-btn">Search</button>
            </form>
        </div>
    </section>

    <!-- SECTION 1: Featured Flights -->
    <section class="data-section">
        <div class="grid-container">
            <div class="section-header" style="grid-column: 1 / -1;">
                <h2>Popular Flights</h2>
                <a href="/flights" class="view-all">View All Flights &rarr;</a>
            </div>
            
            <!-- Hardcoded Example 1 -->
            <div class="item-card">
                <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1542051812-ba32e18ce6a3?auto=format&fit=crop&w=600&q=80');"></div>
                <div class="item-details">
                    <div class="item-title">Singapore to Tokyo</div>
                    <div class="item-subtitle">Direct Flight • 7h 10m</div>
                    <div class="item-price">$450.00</div>
                    <a href="/flights" class="btn book-btn">Book Flight</a>
                </div>
            </div>

            <!-- Hardcoded Example 2 -->
            <div class="item-card">
                <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1530122037265-a5f1f91d3b99?auto=format&fit=crop&w=600&q=80');"></div>
                <div class="item-details">
                    <div class="item-title">Singapore to Zurich</div>
                    <div class="item-subtitle">1 Stop • 14h 20m</div>
                    <div class="item-price">$890.00</div>
                    <a href="/flights" class="btn book-btn">Book Flight</a>
                </div>
            </div>

            <!-- Hardcoded Example 3 -->
            <div class="item-card">
                <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?auto=format&fit=crop&w=600&q=80');"></div>
                <div class="item-details">
                    <div class="item-title">Singapore to Cairo</div>
                    <div class="item-subtitle">1 Stop • 11h 45m</div>
                    <div class="item-price">$620.00</div>
                    <a href="/flights" class="btn book-btn">Book Flight</a>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 2: Trending Hotels -->
    <section class="data-section bg-light">
        <div class="grid-container">
            <div class="section-header" style="grid-column: 1 / -1;">
                <h2>Trending Hotels</h2>
                <a href="/hotels" class="view-all">View All Hotels &rarr;</a>
            </div>
            
            <div class="item-card">
                <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=600&q=80');"></div>
                <div class="item-details">
                    <div class="item-title">The Alpine Retreat</div>
                    <div class="item-subtitle">Swiss Alps, Switzerland • ⭐⭐⭐⭐</div>
                    <div class="item-price">$210.00 <span style="font-size:14px; color:#888; font-weight:400;">/ night</span></div>
                    <a href="/hotels" class="btn book-btn">Reserve Room</a>
                </div>
            </div>

            <div class="item-card">
                <div class="item-img" style="background-image: url('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&q=80');"></div>
                <div class="item-details">
                    <div class="item-title">Shibuya Grand Hotel</div>
                    <div class="item-subtitle">Tokyo, Japan • ⭐⭐⭐⭐⭐</div>
                    <div class="item-price">$340.00 <span style="font-size:14px; color:#888; font-weight:400;">/ night</span></div>
                    <a href="/hotels" class="btn book-btn">Reserve Room</a>
                </div>
            </div>
        </div>
    </section>

    <script>
        // 1. CAROUSEL LOGIC
        const images = [
            'https://images.unsplash.com/photo-1483347756197-71ef80e95f73?auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?auto=format&fit=crop&w=1920&q=80',
            'https://images.unsplash.com/photo-1536098561742-ca998e48cbcc?auto=format&fit=crop&w=1920&q=80', 
            'https://images.unsplash.com/photo-1522383225653-ed111181a951?auto=format&fit=crop&w=1920&q=80', 
            'https://images.unsplash.com/photo-1530122037265-a5f1f91d3b99?auto=format&fit=crop&w=1920&q=80'  
        ];

        function preloadImages(imageArray) {
            imageArray.forEach(src => {
                const img = new Image();
                img.src = src;
            });
        }

        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        preloadImages(images);

        const layer1 = document.getElementById('carousel-layer-1');
        const layer2 = document.getElementById('carousel-layer-2');
        const randomizedImages = shuffleArray([...images]);
        
        let currentIndex = 0;
        let showingLayer1 = true;

        layer1.style.backgroundImage = `url('${randomizedImages[currentIndex]}')`;

        setInterval(() => {
            currentIndex = (currentIndex + 1) % randomizedImages.length;
            const nextImage = `url('${randomizedImages[currentIndex]}')`;

            if (showingLayer1) {
                layer2.style.backgroundImage = nextImage;
                layer2.classList.add('active');
                layer1.classList.remove('active');
            } else {
                layer1.style.backgroundImage = nextImage;
                layer1.classList.add('active');
                layer2.classList.remove('active');
            }
            showingLayer1 = !showingLayer1;
        }, 5000); 

        // 2. SEARCH WIDGET TAB LOGIC
        function switchTab(tabType) {
            const tabs = document.querySelectorAll('.tab');
            tabs.forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            
            // In the future, this function can be expanded to change the form inputs 
            // depending on whether the user is searching for flights or hotels.
        }
    </script>
</body>
</html>